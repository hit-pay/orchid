{
  "name": "Modal",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/overlay-modal-ocmodal--docs",
  "props": {
    "isBorderless": {
      "type": "boolean",
      "required": false
    },
    "footerClass": {
      "type": "string",
      "required": false,
      "default": "justify-end"
    },
    "modelValue": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "title": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "description": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "persistent": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isCloseIcon": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "cancelButtonProps": {
      "type": "object",
      "required": false,
      "default": "{\n  label: 'Cancel',\n  variant: 'secondary'\n}"
    },
    "preventClose": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isHeaderVisible": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "isFooterVisible": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "modalId": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "confirmButtonProps": {
      "type": "object",
      "required": false,
      "default": "{\n  label: 'OK',\n  class: 'min-w-[112px]'\n}"
    },
    "size": {
      "type": "enum",
      "required": false,
      "default": "default",
      "values": [
        "default",
        "medium",
        "small"
      ]
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    },
    "confirm": {
      "description": ""
    },
    "cancel": {
      "description": ""
    },
    "click:outside": {
      "description": ""
    },
    "content-scroll": {
      "description": ""
    }
  },
  "slots": {
    "header": {
      "description": ""
    },
    "description": {
      "description": ""
    },
    "default": {
      "description": ""
    },
    "footer": {
      "description": ""
    }
  },
  "rules": [
    "\"size\" must be one of: default, medium, small"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "title": "Modal Title",
        "description": "Modal Description",
        "isCloseIcon": true,
        "cancelButtonProps": {
          "label": "Cancel",
          "variant": "secondary"
        },
        "confirmButtonProps": {
          "label": "OK"
        },
        "size": "medium"
      }
    }
  ]
}