{
  "name": "OnboardingAccordion",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/disclosure-onboardingaccordion-onboardingaccordion--docs",
  "props": {
    "description": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "title": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "isBorder": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "variant": {
      "type": "enum",
      "required": false,
      "default": "current",
      "values": [
        "completed",
        "not_completed",
        "current",
        "partially_completed",
        "pending",
        "error"
      ]
    }
  },
  "events": {},
  "slots": {
    "button-group": {
      "description": ""
    },
    "default": {
      "description": ""
    }
  },
  "rules": [
    "\"variant\" must be one of: completed, not_completed, current, partially_completed, pending, error"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "title": "Choose product type",
        "description": "Tell us what type of products you are selling",
        "isBorder": false,
        "variant": "completed"
      },
      "code": "<Theme>\n        <div class=\"w-full flex flex-col gap-y-4\">\n          <OnboardingAccordion v-bind=\"args\">\n            <div class=\"p-10\">Accordion body content</div>\n          </OnboardingAccordion>\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}