{
  "name": "OnboardingAccordion",
  "description": "An onboarding-styled accordion with a status variant (completed, error, pending, etc.).",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/disclosure-onboardingaccordion-onboardingaccordion--docs",
  "props": {
    "description": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "title": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "isBorder": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "variant": {
      "type": "enum",
      "required": false,
      "default": "current",
      "values": [
        "completed",
        "not_completed",
        "current",
        "partially_completed",
        "pending",
        "error"
      ]
    }
  },
  "events": {},
  "slots": {
    "button-group": {
      "description": ""
    },
    "default": {
      "description": ""
    }
  },
  "rules": [
    "\"variant\" must be one of: completed, not_completed, current, partially_completed, pending, error"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "title": "Choose product type",
        "description": "Tell us what type of products you are selling",
        "isBorder": false,
        "variant": "completed"
      }
    }
  ]
}