{
  "name": "Popper",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/overlay-popper-ocpopper--docs",
  "props": {
    "placement": {
      "type": "enum",
      "required": true,
      "values": [
        "top-start",
        "top",
        "top-end",
        "right-start",
        "right",
        "right-end",
        "bottom-start",
        "bottom",
        "bottom-end",
        "left-start",
        "left",
        "left-end"
      ]
    },
    "popperOptions": {
      "type": "object",
      "required": false,
      "description": "Options passed to the `popper` from `https://popper.js.org/docs/v2/modifiers/`"
    },
    "popperStyle": {
      "type": "object",
      "required": false
    },
    "skidding": {
      "type": "number",
      "required": false,
      "default": "0"
    },
    "distance": {
      "type": "string|number",
      "required": false,
      "default": "5"
    },
    "isFlipEnabled": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "popperClass": {
      "type": "string|array|object",
      "required": false,
      "default": ""
    },
    "isAttachToBody": {
      "type": "boolean",
      "required": false,
      "default": "false"
    }
  },
  "events": {},
  "slots": {
    "default": {
      "description": ""
    },
    "popper": {
      "description": ""
    }
  },
  "rules": [
    "Required props: placement",
    "\"placement\" must be one of: top-start, top, top-end, right-start, right, right-end, bottom-start, bottom, bottom-end, left-start, left, left-end"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "placement": "top",
        "skidding": 0,
        "distance": 5,
        "isFlipEnabled": true
      },
      "code": "<Theme>\n        <div class=\"w-full h-[700px] gap-y-7 flex-col flex items-center pt-[200px]\">\n          <div class=\"w-full\">Red border block is with overflow-hidden</div>\n          <div class=\"w-full h-[200px] border border-oc-error overflow-hidden flex items-center justify-center\">\n            <Popper v-bind=\"args\">\n              <div class=\"bg-oc-gray-100 rounded border border-oc-gray-200 flex items-center justify-center py-2 px-4\">\n                Reference block\n              </div>\n\n              <template #popper>\n                <div class=\"bg-oc-gray-100 max-w-[300px] p-3 rounded border border-oc-gray-200\">\n                  Popper\n                  <div class=\"text-oc-text-300\">\n                    Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s.\n                  </div>\n                </div>\n              </template>\n            </Popper>\n          </div>\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}