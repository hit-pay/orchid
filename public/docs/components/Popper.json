{
  "name": "Popper",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/overlay-popper-ocpopper--docs",
  "props": {
    "placement": {
      "type": "enum",
      "required": true,
      "values": [
        "top-start",
        "top",
        "top-end",
        "right-start",
        "right",
        "right-end",
        "bottom-start",
        "bottom",
        "bottom-end",
        "left-start",
        "left",
        "left-end"
      ]
    },
    "popperOptions": {
      "type": "object",
      "required": false,
      "description": "Options passed to the `popper` from `https://popper.js.org/docs/v2/modifiers/`"
    },
    "popperStyle": {
      "type": "object",
      "required": false
    },
    "skidding": {
      "type": "number",
      "required": false,
      "default": "0"
    },
    "distance": {
      "type": "string|number",
      "required": false,
      "default": "5"
    },
    "isFlipEnabled": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "popperClass": {
      "type": "string|array|object",
      "required": false,
      "default": ""
    },
    "isAttachToBody": {
      "type": "boolean",
      "required": false,
      "default": "false"
    }
  },
  "events": {},
  "slots": {
    "default": {
      "description": ""
    },
    "popper": {
      "description": ""
    }
  },
  "rules": [
    "Required props: placement",
    "\"placement\" must be one of: top-start, top, top-end, right-start, right, right-end, bottom-start, bottom, bottom-end, left-start, left, left-end"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "placement": "top",
        "skidding": 0,
        "distance": 5,
        "isFlipEnabled": true
      }
    }
  ]
}