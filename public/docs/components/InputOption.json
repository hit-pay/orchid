{
  "name": "InputOption",
  "description": "A tag-style input that lets users add multiple free-text options.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-input-ocinputoption--docs",
  "props": {
    "label": {
      "type": "string",
      "required": false
    },
    "hint": {
      "type": "string",
      "required": false
    },
    "errorMessage": {
      "type": "string",
      "required": false
    },
    "placeholder": {
      "type": "string",
      "required": false
    },
    "isInlineLabel": {
      "type": "boolean",
      "required": false
    },
    "isReadonly": {
      "type": "boolean",
      "required": false
    },
    "isDisabled": {
      "type": "boolean",
      "required": false
    },
    "modelValue": {
      "type": "array",
      "required": false
    },
    "maxVisibleOptions": {
      "type": "number",
      "required": false,
      "default": "2"
    },
    "isRequired": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "allowDuplicated": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "labelIcon": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipText": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipOptions": {
      "type": "object",
      "required": false,
      "default": "{}"
    }
  },
  "events": {
    "blur": {
      "description": ""
    },
    "update:modelValue": {
      "description": ""
    },
    "option-added": {
      "description": ""
    },
    "option-removed": {
      "description": ""
    }
  },
  "slots": {
    "default": {
      "description": "",
      "bindings": [
        {
          "name": "options"
        },
        {
          "name": "are-all-options-visible"
        }
      ]
    }
  },
  "rules": [],
  "examples": []
}