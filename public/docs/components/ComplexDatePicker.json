{
  "name": "ComplexDatePicker",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-complexdatepicker-occomplexdatepicker--docs",
  "props": {
    "shortcuts": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "cancelButtonProps": {
      "type": "object",
      "required": false
    },
    "submitButtonProps": {
      "type": "object",
      "required": false
    },
    "calendarProps": {
      "type": "object",
      "required": false,
      "description": "Props to pass to the calendar component from https://vcalendar.io/"
    },
    "modelValue": {
      "type": "object",
      "required": false,
      "default": "{\n  start: new Date(),\n  end: new Date()\n}"
    },
    "formatDate": {
      "type": "enum",
      "required": false,
      "default": "DD/MM/YYYY",
      "values": [
        "DD/MM/YYYY",
        "MM/DD/YYYY",
        "YYYY/MM/DD"
      ]
    },
    "countCalendars": {
      "type": "number",
      "required": false,
      "default": "2"
    },
    "withFooter": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "label": {
      "type": "string",
      "required": false
    },
    "hint": {
      "type": "string",
      "required": false
    },
    "isRequired": {
      "type": "boolean",
      "required": false
    },
    "errorMessage": {
      "type": "string",
      "required": false
    },
    "labelIcon": {
      "type": "string",
      "required": false
    },
    "tooltipText": {
      "type": "string",
      "required": false
    },
    "tooltipOptions": {
      "type": "object",
      "required": false
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {},
  "rules": [
    "\"formatDate\" must be one of: DD/MM/YYYY, MM/DD/YYYY, YYYY/MM/DD"
  ],
  "examples": [
    {
      "name": "Default",
      "code": "<Theme class=\"h-[400px]\">\n        <ComplexDatePicker v-model=\"modelValue\" v-bind=\"args\" />\n      </Theme>"
    }
  ],
  "relatedComponents": []
}