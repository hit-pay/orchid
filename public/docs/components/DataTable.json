{
  "name": "DataTable",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/datatable-ocdatatable--docs",
  "props": {
    "isLoading": {
      "type": "boolean",
      "required": false
    },
    "id": {
      "type": "string",
      "required": true
    },
    "options": {
      "type": "object",
      "required": true
    },
    "filter": {
      "type": "object",
      "required": false,
      "default": "{}"
    },
    "selected": {
      "type": "array",
      "required": false
    },
    "rowClass": {
      "type": "string",
      "required": false
    },
    "rowKey": {
      "type": "string|func",
      "required": false,
      "default": "id"
    },
    "rowLink": {
      "type": "string",
      "required": false
    },
    "isNewTable": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "selectedIndex": {
      "type": "number",
      "required": false,
      "default": "-1"
    }
  },
  "events": {
    "update:selected": {
      "description": ""
    },
    "click:row": {
      "description": ""
    },
    "hover:cell": {
      "description": ""
    },
    "filter-open": {
      "description": ""
    },
    "update:filter": {
      "description": ""
    },
    "apply-filter": {
      "description": ""
    },
    "filter-fields-changed": {
      "description": ""
    },
    "filter-removed": {
      "description": ""
    },
    "search-query-changed": {
      "description": ""
    },
    "columns-changed": {
      "description": ""
    },
    "on-table-ready": {
      "description": ""
    }
  },
  "slots": {
    "before": {
      "description": ""
    },
    "bulk-actions": {
      "description": "",
      "bindings": [
        {
          "name": "selected-rows"
        }
      ]
    },
    "filter-options": {
      "description": ""
    },
    "custom-filter-form": {
      "description": "",
      "bindings": [
        {
          "name": "errors"
        },
        {
          "name": "values"
        },
        {
          "name": "json-form"
        },
        {
          "name": "update-filter"
        }
      ]
    },
    "header.key": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        },
        {
          "name": "data"
        },
        {
          "name": "item"
        }
      ]
    },
    "`header-${header.key}-tooltip`": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        },
        {
          "name": "data"
        },
        {
          "name": "item"
        }
      ]
    },
    "`header-${header.key}-left-tooltip`": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        },
        {
          "name": "data"
        },
        {
          "name": "item"
        }
      ]
    },
    "after": {
      "description": ""
    },
    "empty": {
      "description": ""
    },
    "table-header": {
      "description": ""
    },
    "table-body": {
      "description": ""
    },
    "after-rows": {
      "description": ""
    },
    "before-pagination": {
      "description": ""
    }
  },
  "rules": [
    "Required props: id, options"
  ],
  "examples": [
    {
      "name": "Default",
      "code": "<Theme class=\"p-8\">\n        <DataTable\n          id=\"sample-data-table\"\n          v-model:selected=\"selectedRows\"\n          row-key=\"id\"\n          row-link=\"link\"\n          :filter=\"filter\"\n          :options=\"args.options\"\n          :is-loading=\"args.isLoading\"\n          @update:filter=\"updateFilterData\"\n          @click:row=\"onClickRow\"\n          @filter-fields-changed=\"changedFields = $event\"\n          @hover:cell=\"console.log('hover:cell: ', $event)\"\n        >\n          <template #bulk-actions=\"{selectedRows}\">\n            <Button label=\"Publish\" size=\"small\" is-transparent left-icon=\"eye-open\" />\n            <Button label=\"Unpublish\" is-transparent size=\"small\" variant=\"secondary\" left-icon=\"eye-close\" />\n            <Button label=\"Delete\" is-transparent size=\"small\" variant=\"destructive\" left-icon=\"bin\" />\n          </template>\n          <template #col1=\"{ item }\">\n            <TableCellContent important :title=\"item.imageTitle\" :description=\"item.imageDescription\"/>\n          </template>\n          <template #col4=\"{ data }\">\n            <span class=\"text-oc-text-400 text-sm\">{{ data }}</span>\n          </template>\n          <template #col6=\"{ data }\">\n            <div class=\"flex gap-3 items-center\">\n              <Toggle size=\"small\" v-model=\"data\"/>\n              <span class=\"md:hidden\">status</span>\n            </div>\n          </template>\n          <template #actions=\"{ item }\">\n            <Dropdown\n              v-model=\"showDropdown[item.id]\"\n              :distance=\"10\"\n              @update:modelValue=\"handleOpenDropdown(item.id)\"\n            >\n              <Icon class=\"w-6 h-6 group-hover/row:block md:hidden cursor-pointer mx-auto\" name=\"dots-vertical\"/>\n              <template #menu>\n                <div class=\"flex flex-col\">\n                  <div class=\"p-2 border-b border-gray-200\">\n                    <DropdownItem text=\"Copy Link\" icon=\"copy\" />\n                    <DropdownItem text=\"Resend e-mail\" icon=\"telegram\" />\n                    <DropdownItem text=\"Download PDF\" icon=\"download\" />\n                  </div>\n                  <div class=\"p-2\">\n                    <DropdownItem text=\"Delete\" icon=\"bin\" variant=\"destructive\" />\n                  </div>\n                </div>\n              </template>\n            </Dropdown>\n          </template>\n        </DataTable>\n      </Theme>"
    },
