{
  "name": "DataTable",
  "description": "A full-featured data table with integrated filtering, search, pagination, column config, and bulk actions.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/datatable-ocdatatable--docs",
  "props": {
    "isLoading": {
      "type": "boolean",
      "required": false
    },
    "id": {
      "type": "string",
      "required": true
    },
    "options": {
      "type": "object",
      "required": true
    },
    "filter": {
      "type": "object",
      "required": false,
      "default": "{}"
    },
    "selected": {
      "type": "array",
      "required": false
    },
    "rowClass": {
      "type": "string",
      "required": false
    },
    "rowKey": {
      "type": "string|func",
      "required": false,
      "default": "id"
    },
    "rowLink": {
      "type": "string",
      "required": false
    },
    "isNewTable": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "selectedIndex": {
      "type": "number",
      "required": false,
      "default": "-1"
    }
  },
  "events": {
    "update:selected": {
      "description": ""
    },
    "click:row": {
      "description": ""
    },
    "hover:cell": {
      "description": ""
    },
    "filter-open": {
      "description": ""
    },
    "update:filter": {
      "description": ""
    },
    "apply-filter": {
      "description": ""
    },
    "filter-fields-changed": {
      "description": ""
    },
    "filter-removed": {
      "description": ""
    },
    "search-query-changed": {
      "description": ""
    },
    "columns-changed": {
      "description": ""
    },
    "on-table-ready": {
      "description": ""
    }
  },
  "slots": {
    "before": {
      "description": ""
    },
    "bulk-actions": {
      "description": "",
      "bindings": [
        {
          "name": "selected-rows"
        }
      ]
    },
    "filter-options": {
      "description": ""
    },
    "custom-filter-form": {
      "description": "",
      "bindings": [
        {
          "name": "errors"
        },
        {
          "name": "values"
        },
        {
          "name": "json-form"
        },
        {
          "name": "update-filter"
        }
      ]
    },
    "header.key": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        },
        {
          "name": "data"
        },
        {
          "name": "item"
        }
      ]
    },
    "`header-${header.key}-tooltip`": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        },
        {
          "name": "data"
        },
        {
          "name": "item"
        }
      ]
    },
    "`header-${header.key}-left-tooltip`": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        },
        {
          "name": "data"
        },
        {
          "name": "item"
        }
      ]
    },
    "after": {
      "description": ""
    },
    "empty": {
      "description": ""
    },
    "table-header": {
      "description": ""
    },
    "table-body": {
      "description": ""
    },
    "after-rows": {
      "description": ""
    },
    "before-pagination": {
      "description": ""
    }
  },
  "rules": [
    "Required props: id, options"
  ],
  "examples": [
    {
      "name": "FilterTabSameKeyFilterDefault",
      "props": {
        "options": {
          "pagination": {
            "total": 50,
            "last_page": 20
          },
          "filterOptions": {
            "per_page": {
              "key": "per_page"
            },
            "tabs": {
              "key": "status",
              "options": [
                {
                  "label": "All",
                  "value": ""
                },
                {
                  "label": "Filter 01",
