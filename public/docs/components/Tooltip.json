{
  "name": "Tooltip",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/overlay-tooltip-octooltip--docs",
  "props": {
    "popperClass": {
      "type": "string",
      "required": false,
      "default": "bg-oc-bg-light"
    },
    "distance": {
      "type": "string|number",
      "required": false,
      "default": "5"
    },
    "skidding": {
      "type": "number",
      "required": false,
      "default": "0"
    },
    "transitionName": {
      "type": "string",
      "required": false,
      "default": "fade"
    },
    "hideAfter": {
      "type": "number",
      "required": false
    },
    "popperOptions": {
      "type": "object",
      "required": false
    },
    "trigger": {
      "type": "enum",
      "required": false,
      "default": "hover",
      "values": [
        "hover",
        "click"
      ]
    },
    "position": {
      "type": "enum",
      "required": false,
      "default": "bottom",
      "values": [
        "top-start",
        "top",
        "top-end",
        "right-start",
        "right",
        "right-end",
        "bottom-start",
        "bottom",
        "bottom-end",
        "left-start",
        "left",
        "left-end"
      ]
    },
    "arrowHidden": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isPopover": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isAttachToBody": {
      "type": "boolean",
      "required": false,
      "default": "false"
    }
  },
  "events": {},
  "slots": {
    "default": {
      "description": ""
    },
    "popper": {
      "description": ""
    }
  },
  "rules": [
    "\"trigger\" must be one of: hover, click",
    "\"position\" must be one of: top-start, top, top-end, right-start, right, right-end, bottom-start, bottom, bottom-end, left-start, left, left-end"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "position": "bottom",
        "trigger": "hover",
        "distance": 10,
        "skidding": 0,
        "isAttachToBody": false
      },
      "code": "<Theme>\n        <div class=\"w-full h-[400px] flex items-center justify-center\">\n          <Tooltip v-bind=\"args\">\n            <button class=\"px-4 py-2 bg-oc-gray-100 rounded\">Hover me</button>\n\n            <template #popper>\n              <div class=\"flex w-[300px] flex-col gap-y-3 p-4\">\n                <div class=\"font-medium\">Tooltip title</div>\n                <div class=\"text-sm\">Tooltips are used to describe or identify an element. In most scenarios, tooltips help the user understand the meaning, function or alt-text of an element.</div>\n              </div>\n            </template>\n          </Tooltip>\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}