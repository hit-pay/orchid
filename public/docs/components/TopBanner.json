{
  "name": "TopBanner",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/elements-topbanner-octopbanner--docs",
  "props": {
    "chipProps": {
      "type": "object",
      "required": false,
      "default": "null"
    },
    "secondaryButton": {
      "type": "object",
      "required": false,
      "default": "null"
    },
    "title": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "rawHtml": {
      "type": "string",
      "required": false,
      "default": "null"
    },
    "buttonLabel": {
      "type": "string",
      "required": false
    },
    "titleClass": {
      "type": "string",
      "required": false
    }
  },
  "events": {
    "click:button": {
      "description": ""
    }
  },
  "slots": {},
  "rules": [],
  "examples": [
    {
      "name": "Default",
      "props": {
        "title": "To start accepting recurring payments, please activate a payment method that supports it.",
        "buttonLabel": "Activate payment method"
      }
    },
    {
      "name": "ActionRequired",
      "props": {
        "chipProps": {
          "label": "Action Required",
          "variant": "warning",
          "class": "shrink-0",
          "icon": "alert-fill"
        },
        "titleClass": "flex-1",
        "rawHtml": "We will stop using <span class=\"underline font-medium\">Cards (by Adyen)</span> soon. To prevent payment disruptions, complete your onboarding to the new payment method \"Cards\" by 21 Nov '25.",
        "buttonLabel": "Complete now"
      }
    }
  ]
}