{
  "name": "Avatar",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/mediaandicons-avatar-ocavatar--docs",
  "props": {
    "size": {
      "type": "enum",
      "required": false,
      "default": "32",
      "values": [
        64,
        48,
        40,
        32,
        28,
        24
      ]
    },
    "type": {
      "type": "enum",
      "required": false,
      "default": "default",
      "values": [
        "business",
        "default",
        "image"
      ]
    }
  },
  "events": {},
  "slots": {
    "default": {
      "description": ""
    }
  },
  "rules": [
    "\"size\" must be one of: 64, 48, 40, 32, 28, 24",
    "\"type\" must be one of: business, default, image"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "size": 32,
        "type": "default"
      },
      "code": "<Theme>\n        <div class=\"w-full h-[400px] flex items-center justify-center\">\n          <Avatar v-bind=\"args\" />\n        </div>\n      </Theme>"
    },
    {
      "name": "Sizes",
      "code": "<Theme>\n        <div class=\"w-full flex gap-x-6\">\n          <div class=\"flex flex-col gap-y-4\">\n            <Avatar v-for=\"size in [64, 48, 40, 32, 24]\" :key=\"size\" :size=\"size\" />\n          </div>\n          <div class=\"flex flex-col gap-y-4\">\n            <Avatar v-for=\"size in [64, 48, 40, 32, 24]\" :key=\"size\" :size=\"size\" type=\"business\" />\n          </div>\n          <div class=\"flex flex-col gap-y-4\">\n            <Avatar v-for=\"size in [64, 48, 40, 32, 24]\" :key=\"size\" :size=\"size\" type=\"image\" />\n          </div>\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}