{
  "name": "Steps",
  "description": "A step indicator showing progress through a multi-step flow.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/disclosure-steps-ocsteps--docs",
  "props": {
    "steps": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "modelValue": {
      "type": "number",
      "required": false,
      "default": "0"
    }
  },
  "events": {
    "update:model-value": {
      "description": ""
    }
  },
  "slots": {
    "default": {
      "description": ""
    }
  },
  "rules": [],
  "examples": [
    {
      "name": "Default",
      "props": {
        "steps": [
          {
            "title": "Personal Info"
          },
          {
            "title": "Business Details"
          },
          {
            "title": "Verification"
          }
        ]
      }
    }
  ]
}