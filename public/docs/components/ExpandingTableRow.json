{
  "name": "ExpandingTableRow",
  "description": "A single row within an ExpandingTable, supporting depth indentation and nested children.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/datadisplay-table-expandingtable-ocexpandingtablerow--docs",
  "props": {
    "row": {
      "type": "object",
      "required": false
    },
    "depth": {
      "type": "number",
      "required": false,
      "default": "0"
    },
    "value": {
      "type": "string|number|date|object",
      "required": false,
      "default": "0"
    },
    "headers": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "important": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isTotal": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isAlternative": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isLoading": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isSticky": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "gridTemplateColumns": {
      "type": "string",
      "required": false,
      "default": "32px 200px repeat(${headers.length - 1}, minmax(150px, auto)) 32px"
    }
  },
  "events": {},
  "slots": {
    "row.key": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        },
        {
          "name": "value"
        }
      ]
    },
    "header.key": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        },
        {
          "name": "data"
        },
        {
          "name": "item"
        }
      ]
    },
    "name": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        }
      ]
    }
  },
  "rules": [],
  "examples": []
}