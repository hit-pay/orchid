{
  "name": "SelectOptions",
  "description": "A visual option picker in grid or list layout supporting text, icon, or image options.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-selectoptions-ocselectoptions--docs",
  "props": {
    "isSmallImage": {
      "type": "boolean",
      "required": false
    },
    "variant": {
      "type": "enum",
      "required": false,
      "default": "grid",
      "values": [
        "grid",
        "list",
        "list2"
      ]
    },
    "optionType": {
      "type": "enum",
      "required": false,
      "default": "text",
      "values": [
        "text",
        "icon",
        "image"
      ]
    },
    "label": {
      "type": "string",
      "required": false
    },
    "hint": {
      "type": "string",
      "required": false
    },
    "errorMessage": {
      "type": "string",
      "required": false
    },
    "placeholder": {
      "type": "string",
      "required": false
    },
    "isDisabled": {
      "type": "boolean",
      "required": false
    },
    "borderless": {
      "type": "boolean",
      "required": false
    },
    "options": {
      "type": "array",
      "required": false
    },
    "modelValue": {
      "type": "array|string|number",
      "required": false
    },
    "isRequired": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "labelIcon": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipText": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipOptions": {
      "type": "object",
      "required": false,
      "default": "{}"
    },
    "class": {
      "type": "string",
      "required": false
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {
    "option": {
      "description": "",
      "bindings": [
        {
          "name": "option"
        },
        {
          "name": "selected"
        }
      ]
    }
  },
  "rules": [
    "\"variant\" must be one of: grid, list, list2",
    "\"optionType\" must be one of: text, icon, image"
  ],
  "examples": []
}