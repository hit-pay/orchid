{
  "name": "SelectOptions",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-selectoptions-ocselectoptions--docs",
  "props": {
    "isSmallImage": {
      "type": "boolean",
      "required": false
    },
    "variant": {
      "type": "enum",
      "required": false,
      "default": "grid",
      "values": [
        "grid",
        "list",
        "list2"
      ]
    },
    "optionType": {
      "type": "enum",
      "required": false,
      "default": "text",
      "values": [
        "text",
        "icon",
        "image"
      ]
    },
    "label": {
      "type": "string",
      "required": false
    },
    "hint": {
      "type": "string",
      "required": false
    },
    "errorMessage": {
      "type": "string",
      "required": false
    },
    "placeholder": {
      "type": "string",
      "required": false
    },
    "isDisabled": {
      "type": "boolean",
      "required": false
    },
    "borderless": {
      "type": "boolean",
      "required": false
    },
    "options": {
      "type": "array",
      "required": false
    },
    "modelValue": {
      "type": "array|string|number",
      "required": false
    },
    "isRequired": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "labelIcon": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipText": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipOptions": {
      "type": "object",
      "required": false,
      "default": "{}"
    },
    "class": {
      "type": "string",
      "required": false
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {
    "option": {
      "description": "",
      "bindings": [
        {
          "name": "option"
        },
        {
          "name": "selected"
        }
      ]
    }
  },
  "rules": [
    "\"variant\" must be one of: grid, list, list2",
    "\"optionType\" must be one of: text, icon, image"
  ],
  "examples": [
    {
      "name": "Default",
      "code": "<Theme>\n        <SelectOptions\n          v-model=\"modelValue\"\n          v-bind=\"args\"\n        />\n      </Theme>"
    },
    {
      "name": "Variants",
      "code": "<Theme>\n        <div class=\"flex flex-col gap-y-6\">\n          <SelectOptions\n            v-model=\"grid\"\n            label=\"Grid (default)\"\n            hint=\"Select one of the options below.\"\n            variant=\"grid\"\n            :options=\"[\n              { label: 'Option 1', value: 1 },\n              { label: 'Option 2', value: 2 },\n              { label: 'Option 3', value: 3 }\n            ]\"\n          />\n          <SelectOptions\n            v-model=\"list\"\n            label=\"List\"\n            hint=\"Select one of the options below.\"\n            variant=\"list\"\n            :options=\"[\n              { label: 'Option 1', value: 1, description: 'Description for option 1' },\n              { label: 'Option 2', value: 2, description: 'Description for option 2' },\n              { label: 'Option 3', value: 3, description: 'Description for option 3' }\n            ]\"\n          />\n          <SelectOptions\n            v-model=\"list2\"\n            label=\"List 2\"\n            hint=\"Select one of the options below.\"\n            variant=\"list2\"\n            :options=\"[\n              { label: 'Option 1', value: 1, description: 'Smaller height, fits screen width' },\n              { label: 'Option 2', value: 2, description: 'Smaller height, fits screen width' }\n            ]\"\n          />\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}