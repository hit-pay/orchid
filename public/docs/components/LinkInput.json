{
  "name": "LinkInput",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-linkinput-oclinkinput--docs",
  "props": {
    "placeholder": {
      "type": "string",
      "required": false
    },
    "hint": {
      "type": "string",
      "required": false
    },
    "label": {
      "type": "string",
      "required": false
    },
    "errorMessages": {
      "type": "object",
      "required": false,
      "default": "{\n  link: '',\n  title: ''\n}"
    },
    "isInlineLabel": {
      "type": "boolean",
      "required": false
    },
    "isDisabled": {
      "type": "boolean",
      "required": false
    },
    "modelValue": {
      "type": "string",
      "required": false
    },
    "type": {
      "type": "string",
      "required": false
    },
    "title": {
      "type": "string",
      "required": false
    },
    "links": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "isRequired": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "labelIcon": {
      "type": "enum",
      "required": false,
      "default": "",
      "values": [
        "question-mark"
      ]
    },
    "tooltipText": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipOptions": {
      "type": "object",
      "required": false,
      "default": "{}"
    },
    "isEdit": {
      "type": "boolean",
      "required": false
    }
  },
  "events": {
    "update:title": {
      "description": ""
    },
    "update:modelValue": {
      "description": ""
    },
    "update:type": {
      "description": ""
    }
  },
  "slots": {},
  "rules": [
    "\"labelIcon\" must be one of: question-mark"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "label": "Enter Username",
        "placeholder": "@username",
        "isDisabled": false,
        "isRequired": false,
        "isInlineLabel": false,
        "tooltipText": "Tooltip text",
        "tooltipOptions": {
          "position": "top",
          "distance": 10
        },
        "errorMessages": {
          "link": "error",
          "title": "error"
        },
        "links": [
          {
            "value": "facebook",
            "placeholder": "@username",
            "label": "Facebook",
            "icon": "facebook",
            "preFill": "https://facebook.com/"
          },
          {
            "value": "instagram",
            "label": "Instagram",
            "icon": "instagram",
            "preFill": "https://instagram.com/"
          },
          {
            "value": "twitter",
            "label": "(X) Twitter",
            "icon": "twitter",
            "preFill": "https://twitter.com/"
          },
          {
            "value": "tiktok",
            "label": "Tiktok",
            "icon": "tiktok",
            "preFill": "https://tiktok.com/"
          },
          {
            "value": "link",
            "label": "Other website",
            "placeholder": "website.com",
            "icon": "earth",
            "preFill": "https://"
          }
        ]
      }
    }
  ]
}