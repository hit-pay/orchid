              "color": "#356DFF"
            }
          },
          {
            "value": 200,
            "name": "Paynow",
            "itemStyle": {
              "color": "#AEC5FF"
            }
          },
          {
            "value": 100,
            "name": "Others",
            "itemStyle": {
              "color": "#86FFCC"
            }
          }
        ]
      }
    }
  ]
