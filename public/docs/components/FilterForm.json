{
  "name": "FilterForm",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/datatable-ocfilterform--docs",
  "props": {
    "id": {
      "type": "string",
      "required": true
    },
    "jsonForm": {
      "type": "array",
      "required": false
    },
    "values": {
      "type": "object",
      "required": false
    },
    "actions": {
      "type": "object",
      "required": false
    },
    "grid": {
      "type": "object",
      "required": false,
      "default": "null"
    }
  },
  "events": {
    "cancel": {
      "description": ""
    },
    "applyFilter": {
      "description": ""
    },
    "filter-fields-changed": {
      "description": ""
    }
  },
  "slots": {
    "default": {
      "description": "",
      "bindings": [
        {
          "name": "errors"
        },
        {
          "name": "values"
        },
        {
          "name": "json-form"
        },
        {
          "name": "update-form"
        }
      ]
    }
  },
  "rules": [
    "Required props: id"
  ],
  "examples": []
}