{
  "name": "DraggableList",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/elements-draggable-ocdraggablelist--docs",
  "props": {
    "modelValue": {
      "type": "array",
      "required": false
    },
    "iconKey": {
      "type": "string",
      "required": false,
      "default": "icon"
    },
    "isChildren": {
      "type": "boolean",
      "required": false
    },
    "childrenKey": {
      "type": "string",
      "required": false,
      "default": "children"
    },
    "isLink": {
      "type": "boolean",
      "required": false
    },
    "linkKey": {
      "type": "string",
      "required": false,
      "default": "link"
    },
    "unmovable": {
      "type": "boolean",
      "required": false
    },
    "enableStatusVariant": {
      "type": "boolean",
      "required": false
    },
    "classes": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "titleWidth": {
      "type": "string",
      "required": false
    }
  },
  "events": {
    "detectMove": {
      "description": ""
    },
    "click:element": {
      "description": ""
    },
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {
    "title": {
      "description": "",
      "bindings": [
        {
          "name": "item"
        }
      ]
    },
    "before-action": {
      "description": "",
      "bindings": [
        {
          "name": "item"
        }
      ]
    },
    "action": {
      "description": "",
      "bindings": [
        {
          "name": "item"
        }
      ]
    },
    "action-item": {
      "description": "",
      "bindings": [
        {
          "name": "item"
        },
        {
          "name": "index"
        }
      ]
    },
    "content": {
      "description": "",
      "bindings": [
        {
          "name": "item"
        },
        {
          "name": "index"
        }
      ]
    }
  },
  "rules": [],
  "examples": [
    {
      "name": "Default",
      "code": "<Theme>\n        <div class=\"p-4\">{{ model }}</div>\n        <div class=\"w-full min-h-[200px]\">\n          <DraggableList v-model=\"model\" is-link :classes=\"args.classes\">\n            <template #title=\"{item}\">\n              <div class=\"flex w-full\">\n                <div class=\"flex justify-between w-full\">\n                  <div class=\"flex flex-col\">\n                    <span class=\"mb-2\">{{ item.title }}</span>\n                    <span> {{ item.link }} </span>\n                  </div>\n                  <div class=\"flex items-center\">\n                    <span>{{ item.id }} </span>\n                  </div>\n                </div>\n              </div>\n            </template>\n            <template #action-item=\"{item}\">\n              <DropdownItem text=\"Menu\" icon=\"pencil\" @click=\"isOpenedDropdown=false\"/>\n              <DropdownItem text=\"Menu\" icon=\"pencil\" @click=\"isOpenedDropdown=false\"/>\n            </template>\n            <template #action=\"{item}\"><span v-if=\"item.isToggle\"><Toggle size=\"small\" /></span></template>\n            <template #content=\"{item}\">\n              <div v-if=\"item.children\" class=\"flex w-full my-5\">\n                <DraggableList class=\"w-full\" v-model=\"item.children\" is-children is-link>\n                  <template #action-item=\"{item}\">\n                    <DropdownItem text=\"Menu\" icon=\"pencil\" @click=\"isOpenedDropdown=false\"/>\n                    <DropdownItem text=\"Menu\" icon=\"pencil\" @click=\"isOpenedDropdown=false\"/>\n                  </template>\n                  <template #action=\"{item}\"><span v-if=\"item.isToggle\"><Toggle size=\"small\" /></span></template>\n                  <template #content=\"{item}\">\n                    <div v-if=\"item.children\" class=\"flex w-full my-5\">\n                      <DraggableList class=\"w-full\" v-model=\"item.children\" is-children is-link>\n                        <template #action-item=\"{item}\">\n                          <DropdownItem text=\"Menu\" icon=\"pencil\" @click=\"isOpenedDropdown=false\"/>\n                          <DropdownItem text=\"Menu\" icon=\"pencil\" @click=\"isOpenedDropdown=false\"/>\n                        </template>\n                        <template #action=\"{item}\"><span v-if=\"item.isToggle\"><Toggle size=\"small\" /></span></template>\n                      </DraggableList>\n                    </div>\n                  </template>\n                </DraggableList>\n              </div>\n            </template>\n          </DraggableList>\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": [
    "DropdownItem",
    "Toggle"
  ]
}