{
  "name": "AdditionalContent",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/elements-additionalcontent-ocadditionalcontent--docs",
  "props": {
    "mainLink": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "balanceContainerClass": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "userId": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "chipVariant": {
      "type": "enum",
      "required": false,
      "default": "",
      "values": [
        "accent-1",
        "accent-2",
        "success",
        "warning",
        "error",
        "gray"
      ]
    },
    "chipLabel": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "additionalTitle": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "primaryActions": {
      "type": "object",
      "required": false,
      "default": "null"
    },
    "overviewActiveTab": {
      "type": "enum",
      "required": false,
      "default": "",
      "values": [
        "hitpay",
        "card"
      ]
    },
    "customerCardVariant": {
      "type": "enum",
      "required": false,
      "default": "",
      "values": [
        "small",
        "big",
        "float"
      ]
    },
    "customer": {
      "type": "object",
      "required": false,
      "default": "null"
    },
    "customerIsHover": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "customerIsEdit": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "variant": {
      "type": "enum",
      "required": false,
      "default": "default",
      "values": [
        "default",
        "dynamic",
        "balance"
      ]
    },
    "boxes": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "isCustomer": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isLoading": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "overviewItems": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "overviewTabs": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "secondaryButtonProps": {
      "type": "object",
      "required": false,
      "default": "null"
    },
    "moreButtonProps": {
      "type": "object",
      "required": false,
      "default": "null"
    },
    "dropdownProps": {
      "type": "object",
      "required": false,
      "default": "{}"
    },
    "dropdownItems": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "paymentMethods": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "additionalStyling": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "href": {
      "type": "string",
      "required": false,
      "default": ""
    }
  },
  "events": {
    "addCustomer": {
      "description": ""
    },
    "editCustomer": {
      "description": ""
    },
    "changeTab": {
      "description": ""
    }
  },
  "slots": {
    "name": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        }
      ]
    }
  },
  "rules": [
    "\"chipVariant\" must be one of: accent-1, accent-2, success, warning, error, gray",
    "\"overviewActiveTab\" must be one of: hitpay, card",
    "\"customerCardVariant\" must be one of: small, big, float",
    "\"variant\" must be one of: default, dynamic, balance"
  ],
  "examples": [
    {
      "name": "Default",
      "code": "<Theme class=\"h-[300px]\">\n        <AdditionalContent\n          :main-link=\"args.mainLink\"\n          :chip-label=\"args.chipLabel\"\n          :additional-title=\"args.additionalTitle\"\n          :chip-variant=\"args.chipVariant\"\n          :user-id=\"args.userId\"\n          :primary-actions=\"args.primaryActions\"\n          :variant=\"args.variant ?? 'default'\"\n          :boxes=\"args.boxes\"\n          :overview-items=\"args.overviewItems\"\n          :overview-tabs=\"args.overviewTabs\"\n          :customer-card-variant=\"args.customerCardVariant\"\n          :is-customer=\"args.isCustomer\"\n          :customer=\"args.customer\"\n          :overview-active-tab=\"args.overviewActiveTab\"\n          :is-loading=\"args.isLoading\"\n          @change-tab=\"args.overviewActiveTab = $event\"\n        />\n      </Theme>"
    },
    {
      "name": "Dynamic",
      "code": "<Theme class=\"h-[300px]\">\n        <AdditionalContent\n          :main-link=\"args.mainLink\"\n          :chip-label=\"args.chipLabel\"\n          :additional-title=\"args.additionalTitle\"\n          :chip-variant=\"args.chipVariant\"\n          :user-id=\"args.userId\"\n          :primary-actions=\"args.primaryActions\"\n          variant=\"dynamic\"\n          :boxes=\"argTypes['boxes'].options['5 Fields in 2 boxes']\"\n          :overview-items=\"args.overviewItems\"\n          :overview-tabs=\"args.overviewTabs\"\n          :customer-card-variant=\"args.customerCardVariant\"\n          :is-customer=\"args.isCustomer\"\n          :customer=\"args.customer\"\n          :overview-active-tab=\"args.overviewActiveTab\"\n          @change-tab=\"args.overviewActiveTab = $event\"\n        />\n        <AdditionalContent\n          :main-link=\"args.mainLink\"\n          :chip-label=\"args.chipLabel\"\n          :additional-title=\"args.additionalTitle\"\n          :chip-variant=\"args.chipVariant\"\n          :user-id=\"args.userId\"\n          :primary-actions=\"args.primaryActions\"\n          variant=\"dynamic\"\n          :boxes=\"argTypes['boxes'].options['4 Fields']\"\n          :overview-items=\"args.overviewItems\"\n          :overview-tabs=\"args.overviewTabs\"\n          :customer-card-variant=\"args.customerCardVariant\"\n          is-customer\n          customer-is-hover\n          customer-is-edit\n          :customer=\"args.customer\"\n          :overview-active-tab=\"args.overviewActiveTab\"\n          @change-tab=\"args.overviewActiveTab = $event\"\n        >\n          <template #Box=\"{ data, key }\">\n            <OverviewItem\n              v-for=\"(field, index) in data.items\"\n              :key=\"data.key + '-' + index\"\n              is-transparent\n              :title=\"field.title\"\n              :content=\"field.content\"\n            >\n              <template #content>\n                <div class=\"text-oc-success-500\">{{field.content}}</div>\n              </template>\n            </OverviewItem>\n          </template>\n          <template #BoxInfoTooltip>\n            <div class=\"p-4\">\n              <div class=\"text-oc-error\">Tooltip</div>\n            </div>\n          </template>\n          <template #customer-bottom>\n            <div>Customer Bottom</div>\n          </template>\n        </AdditionalContent>\n      </Theme>"
    },
    {
      "name": "Balance",
      "code": "<Theme class=\"h-[300px]\">\n        <AdditionalContent\n          :main-link=\"args.mainLink\"\n          :chip-label=\"args.chipLabel\"\n          :additional-title=\"args.additionalTitle\"\n          :chip-variant=\"args.chipVariant\"\n          :user-id=\"args.userId\"\n          :primary-actions=\"args.primaryActions\"\n          variant=\"balance\"\n          :boxes=\"args.boxes\"\n          :overview-items=\"args.overviewItems\"\n          :overview-tabs=\"args.overviewTabs\"\n          :customer-card-variant=\"args.customerCardVariant\"\n          :is-customer=\"args.isCustomer\"\n          :customer=\"args.customer\"\n          :overview-active-tab=\"args.overviewActiveTab\"\n          @change-tab=\"args.overviewActiveTab = $event\"\n        >\n          <template #hitpay=\"{ tab }\">\n            Test block for hitpay slot\n          </template>\n          <template #footer>\n            Test block for footer slot\n          </template>\n        </AdditionalContent>\n      </Theme>"
    }
  ],
  "relatedComponents": [
    "OverviewItem"
  ]
}