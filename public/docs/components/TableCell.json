{
  "name": "TableCell",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/datadisplay-table-octablecell--docs",
  "props": {
    "isSimple": {
      "type": "boolean",
      "required": false
    },
    "variant": {
      "type": "enum",
      "required": false,
      "default": "default",
      "values": [
        "content",
        "checkbox",
        "chip",
        "datetime",
        "icon",
        "image",
        "empty"
      ]
    },
    "isLast": {
      "type": "boolean",
      "required": false
    },
    "isCopy": {
      "type": "boolean",
      "required": false
    },
    "addDescriptionToCopyClipboard": {
      "type": "boolean",
      "required": false
    },
    "isSelected": {
      "type": "boolean",
      "required": false
    },
    "data": {
      "type": "string|number|object|array|boolean",
      "required": false
    },
    "isLoading": {
      "type": "boolean",
      "required": false
    },
    "chipOptions": {
      "type": "object",
      "required": false
    },
    "content": {
      "type": "object",
      "required": false,
      "default": "{\n  title: null,\n  description: null\n}"
    },
    "datetime": {
      "type": "string",
      "required": false
    },
    "imageClass": {
      "type": "string",
      "required": false,
      "default": "h-full"
    },
    "link": {
      "type": "string",
      "required": false
    }
  },
  "events": {
    "hover:field": {
      "description": ""
    },
    "selected": {
      "description": ""
    },
    "copied": {
      "description": ""
    },
    "click:field": {
      "description": ""
    }
  },
  "slots": {
    "default": {
      "description": ""
    }
  },
  "rules": [
    "\"variant\" must be one of: content, checkbox, chip, datetime, icon, image, empty"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "variant": "content",
        "isSelected": false,
        "isSimple": true,
        "isLast": false,
        "isCopy": false,
        "isLoading": false,
        "chipOptions": {},
        "content": {
          "title": "",
          "description": ""
        },
        "imageClass": "h-full"
      },
      "code": "<Theme>\n        <div class=\"flex group/row\">\n          <TableCell class=\"flex-1\" v-bind=\"args\" variant=\"content\" :content=\"{ title: 'Table Cell', description: 'Row description' }\" />\n          <TableCell class=\"flex-1\" v-bind=\"args\" variant=\"datetime\" :data=\"new Date()\" />\n          <TableCell class=\"flex-1\" v-bind=\"args\" variant=\"content\" :content=\"{ title: 'Copyable', description: 'Click to copy' }\" isCopy />\n          <TableCell class=\"flex-1\" v-bind=\"args\">Default slot</TableCell>\n          <TableCell class=\"flex-1\" v-bind=\"args\" isLoading />\n          <TableCell class=\"flex-1\" v-bind=\"args\" variant=\"icon\" data=\"x\" />\n          <TableCell class=\"flex-1\" v-bind=\"args\" variant=\"image\" />\n          <TableCell class=\"flex-1\" v-bind=\"args\" variant=\"chip\" data=\"label\" :chipOptions=\"{ label: 'primary' }\" />\n          <TableCell class=\"flex-1\" v-bind=\"args\" variant=\"checkbox\" />\n          <TableCell class=\"flex-1\" v-bind=\"args\" variant=\"empty\" />\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}