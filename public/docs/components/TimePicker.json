{
  "name": "TimePicker",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-timepicker-octimepicker--docs",
  "props": {
    "modelValue": {
      "type": "string|date",
      "required": false
    },
    "label": {
      "type": "string",
      "required": false
    },
    "hint": {
      "type": "string",
      "required": false
    },
    "icon": {
      "type": "string",
      "required": false,
      "default": "time"
    },
    "preFill": {
      "type": "string",
      "required": false
    },
    "placeholder": {
      "type": "string",
      "required": false
    },
    "errorMessage": {
      "type": "string",
      "required": false
    },
    "isRequired": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isDisabled": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "labelIcon": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipText": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipOptions": {
      "type": "object",
      "required": false,
      "default": "{}"
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {},
  "rules": [],
  "examples": [
    {
      "name": "Default",
      "props": {
        "disabled": false,
        "is24Hours": false
      }
    }
  ]
}