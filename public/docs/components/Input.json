{
  "name": "Input",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-input-ocinput--docs",
  "props": {
    "disabled": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "errorMessage": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "iconProps": {
      "type": "object",
      "required": false,
      "default": "{}"
    },
    "modelValue": {
      "type": "string|number",
      "required": false,
      "default": ""
    },
    "label": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "hint": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "isInlineLabel": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "ai": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isReadonly": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "placeholder": {
      "type": "string",
      "required": false,
      "default": "Placeholder"
    },
    "icon": {
      "type": "enum",
      "required": false,
      "default": "",
      "values": [
        "circle",
        "search"
      ]
    },
    "inputType": {
      "type": "enum",
      "required": false,
      "default": "text",
      "values": [
        "text",
        "password",
        "email",
        "number"
      ]
    },
    "autocomplete": {
      "type": "string",
      "required": false,
      "default": "one-time-code"
    },
    "preFill": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "hasError": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isRequired": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "labelIcon": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipText": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipOptions": {
      "type": "object",
      "required": false,
      "default": "{}"
    },
    "hasLeadingSeparator": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "inputMode": {
      "type": "enum",
      "required": false,
      "default": "text",
      "values": [
        "text",
        "decimal",
        "numeric",
        "tel",
        "search",
        "email",
        "url"
      ]
    },
    "pattern": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "labelClass": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "inputClass": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "trailingClass": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "leadingClass": {
      "type": "string",
      "required": false,
      "default": ""
    }
  },
  "events": {
    "focus": {
      "description": ""
    },
    "blur": {
      "description": ""
    },
    "update:modelValue": {
      "description": ""
    },
    "paste": {
      "description": ""
    }
  },
  "slots": {
    "trailing": {
      "description": ""
    },
    "icon": {
      "description": ""
    },
    "leading": {
      "description": ""
    },
    "hint": {
      "description": ""
    },
    "right-label": {
      "description": ""
    }
  },
  "rules": [
    "\"icon\" must be one of: circle, search",
    "\"inputType\" must be one of: text, password, email, number",
    "\"inputMode\" must be one of: text, decimal, numeric, tel, search, email, url"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "label": "Label",
        "hint": "This is a hint text to help user.",
        "placeholder": "Placeholder",
        "disabled": false,
        "isRequired": false,
        "inputType": "text",
        "isInlineLabel": false
      },
      "code": "<Theme>\n        <Input\n          v-model=\"modelValue\"\n          v-bind=\"args\"\n        />\n      </Theme>"
    },
    {
      "name": "Variants",
      "code": "<Theme>\n        <div class=\"flex flex-col gap-y-6\">\n          <Input\n            v-model=\"normal\"\n            label=\"Normal\"\n            hint=\"This is a hint text.\"\n            placeholder=\"Placeholder\"\n          />\n          <Input\n            v-model=\"disabled\"\n            label=\"Disabled\"\n            hint=\"This is a hint text.\"\n            placeholder=\"Placeholder\"\n            :disabled=\"true\"\n          />\n          <Input\n            v-model=\"error\"\n            label=\"Error\"\n            hint=\"This is a hint text.\"\n            placeholder=\"Placeholder\"\n            error-message=\"This field is required.\"\n          />\n          <Input\n            v-model=\"inline\"\n            label=\"Inline Label\"\n            placeholder=\"Placeholder\"\n            :is-inline-label=\"true\"\n          />\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}