{
  "name": "ColorPicker",
  "description": "A full color picker input with hex/rgb support.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/dashboard-colorpicker-occolorpicker--docs",
  "props": {
    "modelValue": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "variant": {
      "type": "string",
      "required": false,
      "default": "solid"
    },
    "hideOpacity": {
      "type": "boolean",
      "required": false
    },
    "hideInputColor": {
      "type": "boolean",
      "required": false
    },
    "presetColors": {
      "type": "array",
      "required": false
    },
    "placement": {
      "type": "string",
      "required": false,
      "default": "auto"
    }
  },
  "events": {
    "update:model-value": {
      "description": ""
    }
  },
  "slots": {
    "leading": {
      "description": ""
    },
    "picker-icon": {
      "description": ""
    }
  },
  "rules": [],
  "examples": []
}