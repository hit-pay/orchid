{
  "name": "ColorPicker",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/dashboard-colorpicker-occolorpicker--docs",
  "props": {
    "modelValue": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "variant": {
      "type": "string",
      "required": false,
      "default": "solid"
    },
    "hideOpacity": {
      "type": "boolean",
      "required": false
    },
    "hideInputColor": {
      "type": "boolean",
      "required": false
    },
    "presetColors": {
      "type": "array",
      "required": false
    },
    "placement": {
      "type": "string",
      "required": false,
      "default": "auto"
    }
  },
  "events": {
    "update:model-value": {
      "description": ""
    }
  },
  "slots": {
    "leading": {
      "description": ""
    },
    "picker-icon": {
      "description": ""
    }
  },
  "rules": [],
  "examples": [
    {
      "name": "Default",
      "code": "<Theme>\n        <div class=\"h-[400px]\">\n          <div class=\"mb-2 text-sm\">modelValue: {{ modelValue }}</div>\n          <ColorPicker v-model=\"modelValue\" :show-opacity=\"args.showOpacity\">\n            <template #leading>\n              <Icon name=\"paint\" />\n            </template>\n          </ColorPicker>\n        </div>\n      </Theme>"
    },
    {
      "name": "Gradient",
      "code": "<Theme>\n        <ColorPicker v-model=\"modelValue\" variant=\"gradient\" />\n        <div class=\"h-[400px] w-full mt-3\" :style=\"styleBg\" />\n      </Theme>"
    }
  ],
  "relatedComponents": [
    "Icon"
  ]
}