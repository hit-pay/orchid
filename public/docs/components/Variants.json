{
  "name": "Variants",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/disclosure-variants-ocvariants--docs",
  "props": {
    "variants": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "modelValue": {
      "type": "string|number",
      "required": false,
      "default": ""
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {
    "name": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        }
      ]
    }
  },
  "rules": [],
  "examples": [
    {
      "name": "Default",
      "props": {
        "variants": [
          {
            "label": "Business",
            "value": "business",
            "icon": "user"
          },
          {
            "label": "Sole Proprietor",
            "value": "sole",
            "icon": "user"
          },
          {
            "label": "Individual",
            "value": "individual",
            "icon": "user",
            "isDisabled": true
          }
        ]
      },
      "code": "<Theme>\n        <Variants v-model=\"value\" v-bind=\"args\">\n          <template #business-description>\n            <span class=\"text-oc-text-400 text-sm\">Single-owner businesses without a legal distinction between the owner and the business</span>\n          </template>\n        </Variants>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}