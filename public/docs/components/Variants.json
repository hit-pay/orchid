{
  "name": "Variants",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/disclosure-variants-ocvariants--docs",
  "props": {
    "variants": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "modelValue": {
      "type": "string|number",
      "required": false,
      "default": ""
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {
    "name": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        }
      ]
    }
  },
  "rules": [],
  "examples": [
    {
      "name": "Default",
      "props": {
        "variants": [
          {
            "label": "Business",
            "value": "business",
            "icon": "user"
          },
          {
            "label": "Sole Proprietor",
            "value": "sole",
            "icon": "user"
          },
          {
            "label": "Individual",
            "value": "individual",
            "icon": "user",
            "isDisabled": true
          }
        ]
      }
    }
  ]
}