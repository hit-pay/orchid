{
  "name": "Toggle",
  "description": "A on/off toggle switch with label and disabled state.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-toggle-octoggle--docs",
  "props": {
    "modelValue": {
      "type": "boolean",
      "required": false
    },
    "disabled": {
      "type": "boolean",
      "required": false
    },
    "size": {
      "type": "enum",
      "required": false,
      "default": "default",
      "values": [
        "default",
        "small"
      ]
    },
    "label": {
      "type": "string",
      "required": false
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {},
  "rules": [
    "\"size\" must be one of: default, small"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "size": "default",
        "disabled": false,
        "label": "Label"
      }
    }
  ]
}