{
  "name": "Toggle",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-toggle-octoggle--docs",
  "props": {
    "modelValue": {
      "type": "boolean",
      "required": false
    },
    "disabled": {
      "type": "boolean",
      "required": false
    },
    "size": {
      "type": "enum",
      "required": false,
      "default": "default",
      "values": [
        "default",
        "small"
      ]
    },
    "label": {
      "type": "string",
      "required": false
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {},
  "rules": [
    "\"size\" must be one of: default, small"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "size": "default",
        "disabled": false,
        "label": "Label"
      },
      "code": "<Theme>\n        <Toggle v-model=\"modelValue\" v-bind=\"args\" />\n      </Theme>"
    },
    {
      "name": "Variants",
      "code": "<Theme>\n        <div class=\"grid grid-cols-2 w-fit items-center gap-6\">\n          <Toggle :model-value=\"true\" />\n          <Toggle :model-value=\"true\" size=\"small\" />\n          <Toggle :model-value=\"false\" />\n          <Toggle :model-value=\"false\" size=\"small\" />\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}