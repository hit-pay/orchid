{
  "name": "CardInput",
  "description": "A credit card number input with card type detection and inline label support.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-cardinput-occardinput--docs",
  "props": {
    "placeholder": {
      "type": "string",
      "required": false
    },
    "hint": {
      "type": "string",
      "required": false
    },
    "label": {
      "type": "string",
      "required": false
    },
    "errorMessage": {
      "type": "string",
      "required": false
    },
    "cardType": {
      "type": "enum",
      "required": false,
      "values": [
        "mastercard",
        "visa"
      ]
    },
    "isInlineLabel": {
      "type": "boolean",
      "required": false
    },
    "isDisabled": {
      "type": "boolean",
      "required": false
    },
    "modelValue": {
      "type": "string",
      "required": false
    },
    "isRequired": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "labelIcon": {
      "type": "enum",
      "required": false,
      "default": "",
      "values": [
        "question-mark"
      ]
    },
    "tooltipText": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipOptions": {
      "type": "object",
      "required": false,
      "default": "{}"
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {},
  "rules": [
    "\"cardType\" must be one of: mastercard, visa",
    "\"labelIcon\" must be one of: question-mark"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "hint": "This is a hint text to help user.",
        "placeholder": "Placeholder",
        "isDisabled": false,
        "isRequired": false,
        "isInlineLabel": false,
        "cardType": "mastercard",
        "tooltipText": "Tooltip text",
        "tooltipOptions": {
          "position": "top",
          "distance": 10
        }
      }
    }
  ]
}