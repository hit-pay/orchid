{
  "name": "OnboardingProductOption",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/disclosure-onboardingproduct-onboardingproductoption--docs",
  "props": {
    "productImageUrl": {
      "type": "string",
      "required": true
    },
    "selectable": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "size": {
      "type": "enum",
      "required": false,
      "default": "small",
      "values": [
        "small",
        "medium"
      ]
    },
    "title": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "description": {
      "type": "string",
      "required": false,
      "default": ""
    }
  },
  "events": {},
  "slots": {
    "default": {
      "description": ""
    }
  },
  "rules": [
    "Required props: productImageUrl",
    "\"size\" must be one of: small, medium"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "productImageUrl": "/images/onboarding/product-images/invoice.svg",
        "title": "Account Setup",
        "description": "Complete your personal information and business",
        "size": "medium"
      },
      "code": "<Theme>\n        <div class=\"w-full flex flex-col gap-y-4\">\n          <OnboardingProductOption v-bind=\"args\">\n            <div class=\"flex flex-col\">\n              <Checklist label=\"Account verification\" completed :index=\"1\" :action-button=\"{ label: 'Completed' }\" />\n              <Checklist label=\"Add bank account\" active :index=\"2\" :action-button=\"{ label: 'Continue' }\" />\n              <Checklist label=\"Configure payout\" :index=\"3\" :action-button=\"{ label: 'Setup' }\" />\n            </div>\n          </OnboardingProductOption>\n\n          <div class=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n            <OnboardingProductOption\n              :model-value=\"selected.includes('invoice')\"\n              product-image-url=\"/images/onboarding/product-images/invoice.svg\"\n              title=\"Invoicing\"\n              selectable\n              description=\"Send professional invoices and get paid online.\"\n              @update:model-value=\"(checked) => toggle('invoice', checked)\"\n            />\n            <OnboardingProductOption\n              :model-value=\"selected.includes('shopify')\"\n              product-image-url=\"/images/onboarding/product-images/shopify.svg\"\n              title=\"Shopify\"\n              selectable\n              description=\"Connect your Shopify store and accept payments seamlessly.\"\n              @update:model-value=\"(checked) => toggle('shopify', checked)\"\n            />\n          </div>\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": [
    "Checklist"
  ]
}