{
  "name": "Table",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/datadisplay-table-octable--docs",
  "props": {
    "options": {
      "type": "object",
      "required": true
    },
    "isLoading": {
      "type": "boolean",
      "required": false
    },
    "isBorderless": {
      "type": "boolean",
      "required": false
    },
    "loadingRows": {
      "type": "number",
      "required": false,
      "default": "10"
    },
    "selected": {
      "type": "array",
      "required": false
    },
    "rowKey": {
      "type": "string|func",
      "required": false,
      "default": "id"
    },
    "rowClass": {
      "type": "string|func",
      "required": false
    },
    "isSticky": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isResponsive": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "rowLink": {
      "type": "string",
      "required": false
    },
    "sortBy": {
      "type": "object",
      "required": false,
      "default": "{}"
    }
  },
  "events": {
    "update:sort-by": {
      "description": ""
    },
    "hover:cell": {
      "description": ""
    },
    "click:row": {
      "description": ""
    },
    "update:selected": {
      "description": ""
    }
  },
  "slots": {
    "before": {
      "description": ""
    },
    "table-header": {
      "description": "",
      "bindings": [
        {
          "name": "fields"
        },
        {
          "name": "headers"
        },
        {
          "name": "is-selectable"
        },
        {
          "name": "is-responsive"
        },
        {
          "name": "select-all-rows"
        },
        {
          "name": "is-scroll-on-start"
        },
        {
          "name": "is-scroll-on-end"
        }
      ]
    },
    "`header-${header.key}`": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        }
      ]
    },
    "table-body": {
      "description": "",
      "bindings": [
        {
          "name": "fields"
        },
        {
          "name": "headers"
        },
        {
          "name": "is-scroll-on-end"
        },
        {
          "name": "is-scroll-on-start"
        },
        {
          "name": "on-click-row"
        },
        {
          "name": "is-selectable"
        },
        {
          "name": "is-cursor-pointer"
        },
        {
          "name": "is-responsive"
        },
        {
          "name": "is-sticky"
        },
        {
          "name": "row-link"
        },
        {
          "name": "calculate-row-class"
        }
      ]
    },
    "header.key": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        },
        {
          "name": "item"
        },
        {
          "name": "data"
        },
        {
          "name": "index"
        }
      ]
    },
    "extra": {
      "description": "",
      "bindings": [
        {
          "name": "item"
        },
        {
          "name": "index"
        }
      ]
    },
    "empty": {
      "description": ""
    },
    "after": {
      "description": ""
    }
  },
  "rules": [
    "Required props: options"
  ],
  "examples": [
    {
      "name": "Default",
      "code": "<Theme>\n        <Table\n          v-model=\"selectedRows\"\n          :options=\"args.isSticky ? StickyTableOptions : args.options\"\n          :is-loading=\"args.isLoading\"\n          :is-sticky=\"args.isSticky\"\n          :loadingRows=\"args.loadingRows\"\n          :row-class=\"rowClass\"\n          row-link=\"link\"\n          @click:row=\"onClickRow\"\n        >\n          <template #col6=\"{ data }\">\n            <div class=\"flex gap-3 items-center\">\n              <span class=\"md:hidden\">status</span>\n              <Toggle size=\"small\" v-model=\"data\" />\n            </div>\n          </template>\n          <template #actions>\n            <Icon class=\"w-6 h-6 group-hover/row:block md:hidden cursor-pointer mx-auto\" name=\"dots-vertical\" />\n          </template>\n        </Table>\n      </Theme>"
    },
    {
      "name": "ExtraContent",
      "code": "<Theme>\n        <Table\n          v-model=\"selectedRows\"\n          :options=\"args.options\"\n          :is-loading=\"args.isLoading\"\n          :loadingRows=\"args.loadingRows\"\n          @click-row=\"onClickRow\"\n        >\n          <template #col4=\"{ data }\">\n            <span class=\"text-oc-text-400 text-sm\">{{ data }}</span>\n          </template>\n          <template #col5=\"{ data }\">\n            <Chip variant=\"success\" class=\"w-fit\" :label=\"data\" />\n          </template>\n          <template #col6=\"{ data }\">\n            <div class=\"flex gap-3 items-center\">\n              <span class=\"md:hidden\">status</span>\n              <Toggle size=\"small\" v-model=\"data\" />\n            </div>\n          </template>\n          <template #extra=\"{ item, index }\">\n            <TableCell\n              v-if=\"item.col7\"\n              class=\"flex border-oc-gray-200 w-full\"\n              :is-last=\"args.options.fields.length === index + 1\"\n            >\n              <TextEditor\n                v-model=\"item.col7\"\n                v-bind=\"{fontSizes:[{label:'Default',value:'14px'},{label:'Medium',value:'16px'},{label:'Large',value:'18px'},{label:'Extra Large',value:'20px'}],initialFontSize:'14px'}\"\n              />\n            </TableCell>\n          </template>\n          <template #actions>\n            <Icon class=\"w-6 h-6 group-hover/row:block md:hidden cursor-pointer mx-auto\" name=\"dots-vertical\" />\n          </template>\n        </Table>\n      </Theme>"
    },
    {
      "name": "ExpandingTableStory",
      "props": {
        "isAlternative": true
      },
      "code": "<Theme>\n        <div class=\"p-10\">\n          <ExpandingTable class=\"mb-10\" :is-alternative=\"false\" :headers=\"headers\" :fields=\"fields\">\n            <template #gross_sales=\"{ value }\">\n              {{ value.quick_sale + value.products }}\n            </template>\n          </ExpandingTable>\n          <ExpandingTable is-alternative is-loading :headers=\"headers2\" is-sticky :fields=\"fields2\">\n            <template #total>\n              <div />\n            </template>\n          </ExpandingTable>\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": [
    "Chip",
    "ExpandingTable",
    "Icon",
    "TableCell",
    "TableCellContent",
    "TextEditor",
    "Toggle"
  ]
}