{
  "name": "Tag",
  "description": "A small colored label tag for status or category annotation.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/feedback-tag-octag--docs",
  "props": {
    "variant": {
      "type": "enum",
      "required": false,
      "default": "warning",
      "values": [
        "warning",
        "primary",
        "success",
        "error",
        "gray"
      ]
    },
    "label": {
      "type": "string",
      "required": false,
      "default": ""
    }
  },
  "events": {},
  "slots": {},
  "rules": [
    "\"variant\" must be one of: warning, primary, success, error, gray"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "label": "BETA",
        "variant": "warning"
      }
    }
  ]
}