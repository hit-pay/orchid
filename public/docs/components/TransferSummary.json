{
  "name": "TransferSummary",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/datadisplay-transfersummary-octransfersummary--docs",
  "props": {
    "transfer": {
      "type": "object",
      "required": true
    },
    "hasFxData": {
      "type": "boolean",
      "required": false
    }
  },
  "events": {},
  "slots": {},
  "rules": [
    "Required props: transfer"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "hasFxData": false,
        "transfer": {
          "source_amount": "134.20",
          "source_currency": "sgd",
          "fee": "3.50",
          "fee_currency": "SGD",
          "transfer_method": "Local"
        }
      }
    },
    {
      "name": "WithFxData",
      "props": {
        "hasFxData": true,
        "transfer": {
          "exchange_rate": "0.73774386",
          "source_amount": "1,355.48",
          "source_currency": "sgd",
          "payment_currency": "usd",
          "fee": "3.50",
          "fee_currency": "SGD",
          "transfer_method": "Local"
        }
      }
    }
  ]
}