{
  "name": "ListItem",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/datadisplay-listitem-oclistitem--docs",
  "props": {
    "isActive": {
      "type": "boolean",
      "required": false
    },
    "title": {
      "type": "string",
      "required": false
    },
    "description": {
      "type": "string",
      "required": false
    },
    "descriptionIcon": {
      "type": "string",
      "required": false
    },
    "icon": {
      "type": "enum",
      "required": false,
      "values": [
        "backward",
        "circle",
        "x"
      ]
    },
    "iconClass": {
      "type": "string",
      "required": false
    },
    "iconText": {
      "type": "string",
      "required": false
    },
    "date": {
      "type": "string",
      "required": false
    },
    "type": {
      "type": "enum",
      "required": false,
      "default": "timeLine",
      "values": [
        "timeline",
        "webhook",
        "payment",
        "terminal",
        "general",
        "accordion"
      ]
    },
    "urls": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "paymentMethods": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "chips": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "details": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "isDisabled": {
      "type": "boolean",
      "required": false
    },
    "isTransparent": {
      "type": "boolean",
      "required": false
    },
    "isDraggable": {
      "type": "boolean",
      "required": false
    },
    "isOpenDefault": {
      "type": "boolean",
      "required": false
    },
    "modelValue": {
      "type": "boolean",
      "required": false
    }
  },
  "events": {
    "more": {
      "description": ""
    },
    "edit": {
      "description": ""
    },
    "delete": {
      "description": ""
    },
    "click:item": {
      "description": ""
    },
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {
    "name": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        }
      ]
    }
  },
  "rules": [
    "\"icon\" must be one of: backward, circle, x",
    "\"type\" must be one of: timeline, webhook, payment, terminal, general, accordion"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "active": 1,
        "title": "September, 1 2023 at 05:01PM",
        "icon": "backward",
        "iconClass": "text-oc-error",
        "iconText": "SGD 130.11",
        "description": "#9a2804fc-74df-4304-a7d7-79d11f9e1db8",
        "type": "timeline",
        "image": "https://hitpay-staging-public.s3.ap-southeast-1.amazonaws.com/covers/small/99d696e564ba45fbaa0fb2e3b43d0e27.jpg",
        "imageSize": "small"
      },
      "code": "<Theme class=\"flex flex-col gap-5\">\n        <ListItem\n          v-for=\"i in 5\"\n          :is-active=\"args.active >= i\"\n          :key=\"i\"\n          :type=\"args.type\"\n          :title=\"args.title\"\n          :image=\"args.image\"\n          :image-size=\"args.imageSize\"\n          :icon=\"args.icon\"\n          :icon-class=\"args.iconClass\"\n          :icon-text=\"args.iconText\"\n          :description=\"args.description\"\n        />\n      </Theme>"
    },
    {
      "name": "ListWebhook",
      "props": {
        "urls": [
          {
            "url": "https://orchid.software",
            "title": "URL"
          }
        ]
      },
      "code": "<Theme class=\"p-10\">\n        <ListItem\n          type=\"webhook\"\n          :urls=\"args.urls\"\n          title=\"Zapier Flow\"\n          date=\"Oct, 20 2023\"\n        >\n          <template #menu>\n            <div class=\"p-2 border-b border-gray-200\">\n              <DropdownItem text=\"Edit\" icon=\"pencil\" />\n            </div>\n            <div class=\"p-2\">\n              <DropdownItem text=\"Delete\" variant=\"destructive\" icon=\"bin\" />\n            </div>\n          </template>\n        </ListItem>\n      </Theme>"
    },
    {
      "name": "ListLogo",
      "code": "<Theme class=\"p-10\">\n        <ListItem\n          type=\"logo\"\n          title=\"Zapier Flow\"\n          image=\"/images/partner-logo/web-delegate.png\"\n        />\n      </Theme>"
    },
    {
      "name": "ListPayment",
      "props": {
        "title": "Shopify",
        "paymentMethods": [
          {
            "method": "paynow_online",
            "svg": "http://api.src.test/icons/methods/md/paynow.png",
            "md": "http://api.src.test/icons/methods/md/paynow.png"
          },
          {
            "method": "card",
            "svg": "http://api.src.test/icons/methods/md/visa.png",
            "md": "http://api.src.test/icons/methods/md/visa.png"
          }
        ],
        "description": "Connected payment store"
      },
      "code": "<Theme class=\"p-10\">\n        <ListItem\n          v-bind=\"args\"\n          type=\"payment\"\n        >\n          <template #logo>\n            <div class=\"rounded-sm p-2 bg-oc-accent-1-50\">\n              <img src=\"http://api.src.test/icons/providers/shopee.png\" class=\"w-[32px] h-[32px]\" />\n            </div>\n          </template>\n        </ListItem>\n      </Theme>"
    },
    {
      "name": "ListGeneral",
      "props": {
        "title": "Standard shipping",
        "description": "Calculation Method: Flat",
        "isDisabled": false,
        "chips": [
          {
            "label": "Default"
          },
          {
            "label": "HitPay",
            "variant": "accent-1"
          }
        ],
        "details": [
          {
            "label": "SGD 28.00",
            "icon": "dollar-coin"
          },
          {
            "label": "Singapore",
            "country": "sg"
          }
        ]
      },
      "code": "<Theme class=\"p-10\">\n        <ListItem type=\"general\" v-bind=\"args\">\n          <template #menu>\n            <div class=\"p-2 border-b border-gray-200\">\n              <DropdownItem text=\"Edit\" icon=\"pencil\" />\n            </div>\n            <div class=\"p-2\">\n              <DropdownItem text=\"Delete\" variant=\"destructive\" icon=\"bin\" />\n            </div>\n          </template>\n        </ListItem>\n\n        <ListItem\n          type=\"general\"\n          title=\"Shopee Pay\"\n          :chips=\"[{ label: 'Primary' }]\"\n        >\n          <template #logo>\n            <img src=\"http://api.src.test/icons/providers/shopee.png\" width=\"64\" alt=\"shopee\" />\n          </template>\n        </ListItem>\n\n        <ListItem type=\"general\" v-bind=\"args\" :is-dropdown-actions-visible=\"false\">\n          <template #logo>\n            <img src=\"http://api.src.test/icons/providers/paynow.png\" width=\"64\" />\n          </template>\n          <div class=\"flex gap-x-4\">\n            <img\n              v-for=\"(methodImage, index) in methodLogos\"\n              :key=\"index\"\n              class=\"object-contain\"\n              :src=\"methodImage\"\n              width=\"35\"\n              :alt=\"methodImage\"\n              height=\"24\"\n            />\n          </div>\n          <template #append>\n            <Button label=\"Connect\" />\n          </template>\n        </ListItem>\n      </Theme>"
    },
    {
      "name": "ListItemPage",
      "props": {
        "pages": [
          {
            "id": "9bd54837-2156-417a-9577-8ff20f895769",
            "business_id": "8ba6c772-8c2d-4f3b-a7d6-3f1f0648fa77",
            "title": "Page Title Example",
            "description": "<p><span style=\"font-size:14px;\">Lorem ipsum dolor sit amet consectetur adipisicing elit.</span></p>",
            "enabled": 1,
            "page_path": "page-path-1",
            "page_cover_url": "https://blog.hitpayapp.com/content/images/size/w2000/2024/02/-new--Clarissa-Blog-Design---4-.png",
            "created_at": "2024-04-18T09:23:39+08:00",
            "updated_at": "2024-04-18T09:23:39+08:00"
          },
          {
            "id": "9bb6447e-edab-4c8c-9652-8186cffc8402",
            "business_id": "8ba6c772-8c2d-4f3b-a7d6-3f1f0648fa77",
            "title": "Disabled Page Example",
            "description": "<p><span style=\"font-size:14px;\">Lorem ipsum dolor sit amet consectetur adipisicing elit.</span></p>",
            "enabled": 0,
            "page_path": "page-path-2",
            "page_cover_url": null,
            "created_at": "2024-04-02T23:22:35+08:00",
            "updated_at": "2024-04-18T09:22:56+08:00"
          }
        ]
      },
      "code": "<Theme class=\"p-10\">\n        <ListItem\n          type=\"page\"\n          v-for=\"page in args.pages\"\n          :key=\"page.id\"\n          :page=\"page\"\n        >\n          <template #menu>\n            <div class=\"p-2 border-b border-gray-200\">\n              <DropdownItem text=\"Edit\" icon=\"pencil\" />\n            </div>\n            <div class=\"p-2\">\n              <DropdownItem text=\"Delete\" variant=\"destructive\" icon=\"bin\" />\n            </div>\n          </template>\n        </ListItem>\n      </Theme>"
    },
    {
      "name": "ListItemAccordion",
      "props": {
        "title": "Extra Toppings",
        "description": "Strawberry, Chocolate, and Cheese",
        "isDisabled": false,
        "isTransparent": false,
        "isDraggable": true,
        "isOpenDefault": true,
        "chips": [
          {
            "label": "Required"
          }
        ]
      },
      "code": "<Theme class=\"p-10\">\n        <ListItem v-bind=\"args\" v-model=\"isOpen1\" type=\"accordion\">\n          <template #content>Content</template>\n        </ListItem>\n        <div class=\"my-3\" />\n        <ListItem v-bind=\"args\" v-model=\"isOpen2\" type=\"accordion\" is-no-toggle-forced>\n          <template #content>Content</template>\n        </ListItem>\n      </Theme>"
    }
  ],
  "relatedComponents": [
    "Button",
    "DropdownItem"
  ]
}