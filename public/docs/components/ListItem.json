{
  "name": "ListItem",
  "description": "A versatile list row supporting timeline, webhook, payment, terminal, general, and accordion layouts.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/datadisplay-listitem-oclistitem--docs",
  "props": {
    "isActive": {
      "type": "boolean",
      "required": false
    },
    "title": {
      "type": "string",
      "required": false
    },
    "description": {
      "type": "string",
      "required": false
    },
    "descriptionIcon": {
      "type": "string",
      "required": false
    },
    "icon": {
      "type": "enum",
      "required": false,
      "values": [
        "backward",
        "circle",
        "x"
      ]
    },
    "iconClass": {
      "type": "string",
      "required": false
    },
    "iconText": {
      "type": "string",
      "required": false
    },
    "date": {
      "type": "string",
      "required": false
    },
    "type": {
      "type": "enum",
      "required": false,
      "default": "timeLine",
      "values": [
        "timeline",
        "webhook",
        "payment",
        "terminal",
        "general",
        "accordion"
      ]
    },
    "urls": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "paymentMethods": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "chips": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "details": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "isDisabled": {
      "type": "boolean",
      "required": false
    },
    "isTransparent": {
      "type": "boolean",
      "required": false
    },
    "isDraggable": {
      "type": "boolean",
      "required": false
    },
    "isOpenDefault": {
      "type": "boolean",
      "required": false
    },
    "modelValue": {
      "type": "boolean",
      "required": false
    }
  },
  "events": {
    "more": {
      "description": ""
    },
    "edit": {
      "description": ""
    },
    "delete": {
      "description": ""
    },
    "click:item": {
      "description": ""
    },
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {
    "name": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        }
      ]
    }
  },
  "rules": [
    "\"icon\" must be one of: backward, circle, x",
    "\"type\" must be one of: timeline, webhook, payment, terminal, general, accordion"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
