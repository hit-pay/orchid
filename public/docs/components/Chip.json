{
  "name": "Chip",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/feedback-chip-occhip--docs",
  "props": {
    "variant": {
      "type": "enum",
      "required": false,
      "default": "",
      "values": [
        "primary",
        "accent-1",
        "accent-2",
        "accent-3",
        "success",
        "warning",
        "error",
        "gray",
        "light-red",
        "neutral",
        "tosca"
      ]
    },
    "type": {
      "type": "enum",
      "required": false,
      "default": "background",
      "values": [
        "background",
        "transparent",
        "outlined"
      ]
    },
    "label": {
      "type": "string",
      "required": false
    },
    "icon": {
      "type": "string",
      "required": false
    },
    "iconSize": {
      "type": "string",
      "required": false
    },
    "iconTooltip": {
      "type": "string",
      "required": false
    },
    "closable": {
      "type": "boolean",
      "required": false
    },
    "truncate": {
      "type": "boolean",
      "required": false
    },
    "iconProps": {
      "type": "object",
      "required": false
    }
  },
  "events": {
    "remove": {
      "description": ""
    }
  },
  "slots": {
    "default": {
      "description": ""
    }
  },
  "rules": [
    "\"variant\" must be one of: primary, accent-1, accent-2, accent-3, success, warning, error, gray, light-red, neutral, tosca",
    "\"type\" must be one of: background, transparent, outlined"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "label": "Primary",
        "variant": "primary",
        "type": "background",
        "closable": false
      },
      "code": "<Theme>\n        <Chip v-bind=\"args\" class=\"w-fit\" />\n      </Theme>"
    },
    {
      "name": "AllVariants",
      "code": "<div class=\"grid grid-cols-4 gap-8\">\n        <div>\n          <h3 class=\"text-lg font-semibold mb-4\">Background</h3>\n          <Theme class=\"flex flex-col gap-3\">\n            <Chip label=\"Primary\" type=\"background\" class=\"w-fit\" />\n            <Chip label=\"Accent 1\" variant=\"accent-1\" type=\"background\" class=\"w-fit\" />\n            <Chip label=\"Accent 2\" variant=\"accent-2\" type=\"background\" class=\"w-fit\" />\n            <Chip label=\"Accent 3\" variant=\"accent-3\" type=\"background\" class=\"w-fit\" />\n            <Chip label=\"Success\" variant=\"success\" type=\"background\" class=\"w-fit\" />\n            <Chip label=\"Warning\" variant=\"warning\" type=\"background\" class=\"w-fit\" />\n            <Chip label=\"Error\" variant=\"error\" type=\"background\" class=\"w-fit\" />\n            <Chip label=\"Gray\" variant=\"gray\" type=\"background\" class=\"w-fit\" />\n            <Chip label=\"Light Red\" variant=\"light-red\" type=\"background\" class=\"w-fit\" />\n            <Chip label=\"Neutral\" variant=\"neutral\" type=\"background\" class=\"w-fit\" />\n            <Chip label=\"Tosca\" variant=\"tosca\" type=\"background\" class=\"w-fit\" />\n          </Theme>\n        </div>\n\n        <div>\n          <h3 class=\"text-lg font-semibold mb-4\">Transparent</h3>\n          <Theme class=\"flex flex-col gap-3\">\n            <Chip label=\"Primary\" type=\"transparent\" class=\"w-fit\" />\n            <Chip label=\"Accent 1\" variant=\"accent-1\" type=\"transparent\" class=\"w-fit\" />\n            <Chip label=\"Accent 2\" variant=\"accent-2\" type=\"transparent\" class=\"w-fit\" />\n            <Chip label=\"Accent 3\" variant=\"accent-3\" type=\"transparent\" class=\"w-fit\" />\n            <Chip label=\"Success\" variant=\"success\" type=\"transparent\" class=\"w-fit\" />\n            <Chip label=\"Warning\" variant=\"warning\" type=\"transparent\" class=\"w-fit\" />\n            <Chip label=\"Error\" variant=\"error\" type=\"transparent\" class=\"w-fit\" />\n            <Chip label=\"Gray\" variant=\"gray\" type=\"transparent\" class=\"w-fit\" />\n            <Chip label=\"Light Red\" variant=\"light-red\" type=\"transparent\" class=\"w-fit\" />\n            <Chip label=\"Neutral\" variant=\"neutral\" type=\"transparent\" class=\"w-fit\" />\n            <Chip label=\"Tosca\" variant=\"tosca\" type=\"transparent\" class=\"w-fit\" />\n          </Theme>\n        </div>\n\n        <div>\n          <h3 class=\"text-lg font-semibold mb-4\">Outlined</h3>\n          <Theme class=\"flex flex-col gap-3\">\n            <Chip label=\"Primary\" type=\"outlined\" class=\"w-fit\" />\n            <Chip label=\"Accent 1\" variant=\"accent-1\" type=\"outlined\" class=\"w-fit\" />\n            <Chip label=\"Accent 2\" variant=\"accent-2\" type=\"outlined\" class=\"w-fit\" />\n            <Chip label=\"Accent 3\" variant=\"accent-3\" type=\"outlined\" class=\"w-fit\" />\n            <Chip label=\"Success\" variant=\"success\" type=\"outlined\" class=\"w-fit\" />\n            <Chip label=\"Warning\" variant=\"warning\" type=\"outlined\" class=\"w-fit\" />\n            <Chip label=\"Error\" variant=\"error\" type=\"outlined\" class=\"w-fit\" />\n            <Chip label=\"Gray\" variant=\"gray\" type=\"outlined\" class=\"w-fit\" />\n            <Chip label=\"Light Red\" variant=\"light-red\" type=\"outlined\" class=\"w-fit\" />\n            <Chip label=\"Neutral\" variant=\"neutral\" type=\"outlined\" class=\"w-fit\" />\n            <Chip label=\"Tosca\" variant=\"tosca\" type=\"outlined\" class=\"w-fit\" />\n          </Theme>\n        </div>\n\n        <div>\n          <h3 class=\"text-lg font-semibold mb-4\">Background with Icons</h3>\n          <Theme class=\"flex flex-col gap-3\">\n            <Chip label=\"Primary\" type=\"background\" icon=\"check\" closable class=\"w-fit\" />\n            <Chip label=\"Accent 1\" variant=\"accent-1\" type=\"background\" icon=\"check\" closable class=\"w-fit\" />\n            <Chip label=\"Accent 2\" variant=\"accent-2\" type=\"background\" icon=\"check\" closable class=\"w-fit\" />\n            <Chip label=\"Accent 3\" variant=\"accent-3\" type=\"background\" icon=\"check\" closable class=\"w-fit\" />\n            <Chip label=\"Success\" variant=\"success\" type=\"background\" icon=\"check\" closable class=\"w-fit\" />\n            <Chip label=\"Warning\" variant=\"warning\" type=\"background\" icon=\"check\" closable class=\"w-fit\" />\n            <Chip label=\"Error\" variant=\"error\" type=\"background\" icon=\"check\" closable class=\"w-fit\" />\n            <Chip label=\"Gray\" variant=\"gray\" type=\"background\" icon=\"check\" closable class=\"w-fit\" />\n            <Chip label=\"Light Red\" variant=\"light-red\" type=\"background\" icon=\"check\" closable class=\"w-fit\" />\n            <Chip label=\"Neutral\" variant=\"neutral\" type=\"background\" icon=\"check\" closable class=\"w-fit\" />\n            <Chip label=\"Tosca\" variant=\"tosca\" type=\"background\" icon=\"check\" closable class=\"w-fit\" />\n          </Theme>\n        </div>\n      </div>"
    }
  ],
  "relatedComponents": []
}