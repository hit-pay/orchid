{
  "name": "ConfirmationModal",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/overlay-confirmationmodal-occonfirmationmodal--docs",
  "props": {
    "modelValue": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "title": {
      "type": "string",
      "required": false,
      "default": "Are you sure?"
    },
    "iconClass": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "description": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "variant": {
      "type": "enum",
      "required": false,
      "default": "delete",
      "values": [
        "delete",
        "success",
        "warning",
        "question"
      ]
    },
    "icon": {
      "type": "string",
      "required": false
    },
    "labelConfirm": {
      "type": "string",
      "required": false
    },
    "labelCancel": {
      "type": "string",
      "required": false
    },
    "isLoading": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "hideIcon": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "persistent": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "contentClass": {
      "type": "string",
      "required": false
    },
    "confirmButtonProps": {
      "type": "object",
      "required": false
    }
  },
  "events": {
    "confirm": {
      "description": ""
    },
    "cancel": {
      "description": ""
    },
    "update:model-value": {
      "description": ""
    }
  },
  "slots": {
    "description": {
      "description": ""
    }
  },
  "rules": [
    "\"variant\" must be one of: delete, success, warning, question"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "variant": "delete",
        "title": "Are you sure?",
        "description": "Do you want to delete this item? This action cannot be undone.",
        "labelConfirm": "Confirm",
        "labelCancel": "Cancel",
        "isLoading": false
      },
      "code": "<Theme>\n        <div class=\"h-screen\">\n          <Button label=\"Open Confirmation\" @click=\"isOpen = true\" />\n\n          <ConfirmationModal v-model=\"isOpen\" v-bind=\"args\" />\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": [
    "Button"
  ]
}