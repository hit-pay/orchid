{
  "name": "DatePicker",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-datepicker-datepicker--docs",
  "props": {
    "modelValue": {
      "type": "string|date|number|array",
      "required": false
    },
    "type": {
      "type": "enum",
      "required": false,
      "default": "default",
      "values": [
        "default",
        "range"
      ]
    },
    "disabledDate": {
      "type": "func",
      "required": false,
      "default": "() => false"
    },
    "minDate": {
      "type": "string|date|number",
      "required": false,
      "default": "null"
    },
    "maxDate": {
      "type": "string|date|number",
      "required": false,
      "default": "null"
    },
    "dateFormat": {
      "type": "string",
      "required": false,
      "default": "YYYY-MM-DD"
    },
    "disabled": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "errorMessage": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "label": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "hint": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "placeholder": {
      "type": "string",
      "required": false,
      "default": "YYYY-MM-DD"
    },
    "isSplitInput": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "minLabel": {
      "type": "string",
      "required": false,
      "default": "From"
    },
    "maxLabel": {
      "type": "string",
      "required": false,
      "default": "To"
    },
    "isRequired": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isIndefinite": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "disabledRange": {
      "type": "object",
      "required": false,
      "default": "{\n  start: null,\n  end: null\n}"
    },
    "countCalendars": {
      "type": "number",
      "required": false,
      "default": "2"
    },
    "shortcuts": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "placement": {
      "type": "string",
      "required": false,
      "default": "bottom-start"
    },
    "ai": {
      "type": "boolean",
      "required": false,
      "default": "false"
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    },
    "resetCalendar": {
      "description": ""
    },
    "error": {
      "description": ""
    }
  },
  "slots": {
    "menu": {
      "description": "",
      "bindings": [
        {
          "name": "is-popover-open"
        },
        {
          "name": "update-calendar"
        },
        {
          "name": "reset-calendar"
        }
      ]
    }
  },
  "rules": [
    "\"type\" must be one of: default, range"
  ],
  "examples": []
}