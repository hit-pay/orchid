{
  "name": "Dropdown",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/overlay-dropdown-ocdropdown--docs",
  "props": {
    "distance": {
      "type": "number",
      "required": false,
      "default": "4"
    },
    "skidding": {
      "type": "number",
      "required": false,
      "default": "0"
    },
    "isDisabled": {
      "type": "boolean",
      "required": false
    },
    "menuClasses": {
      "type": "string",
      "required": false
    },
    "placement": {
      "type": "string",
      "required": false,
      "default": "bottom-start"
    },
    "popperOptions": {
      "type": "object",
      "required": false,
      "default": "{}"
    },
    "maxMenuHeight": {
      "type": "number",
      "required": false
    },
    "popperStyle": {
      "type": "object",
      "required": false
    },
    "popperClass": {
      "type": "string|array|object",
      "required": false
    },
    "modelValue": {
      "type": "boolean",
      "required": false
    },
    "preventClickOutside": {
      "type": "boolean",
      "required": false
    },
    "isAttachToBody": {
      "type": "boolean",
      "required": false
    }
  },
  "events": {
    "scroll": {
      "description": ""
    },
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {
    "default": {
      "description": ""
    },
    "menu": {
      "description": "",
      "bindings": [
        {
          "name": "is-popover-open"
        }
      ]
    }
  },
  "rules": [],
  "examples": [
    {
      "name": "Default",
      "props": {
        "distance": 10
      },
      "code": "<Theme>\n        <div class=\"w-full h-[200px]\">\n          <Dropdown v-model=\"isOpen\" v-bind=\"args\">\n            <button>Open Dropdown</button>\n\n            <template #menu>\n              <div class=\"flex flex-col\">\n                <div class=\"p-2 border-b border-gray-200\">\n                  <DropdownItem text=\"Edit\" icon=\"pencil\" />\n                  <DropdownItem text=\"Duplicate\" icon=\"copy\" />\n                  <DropdownItem text=\"Archive\" icon=\"archive\" />\n                </div>\n                <div class=\"p-2\">\n                  <DropdownItem text=\"Delete\" icon=\"trash\" variant=\"destructive\" />\n                </div>\n              </div>\n            </template>\n          </Dropdown>\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": [
    "DropdownItem"
  ]
}