      "name": "Variants",
      "code": "<Theme>\n        <div class=\"grid grid-cols-3 w-fit gap-6\">\n          <Radio :model-value=\"true\" />\n          <Radio :model-value=\"false\" />\n          <Radio :model-value=\"false\" error-message=\"Error\" />\n          <Radio :model-value=\"true\" is-disabled />\n          <Radio :model-value=\"false\" is-disabled />\n        </div>\n      </Theme>"
    },
