{
  "name": "MultipleUploadFile",
  "description": "A file upload input for multiple files with preview grid and size/count limits.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-multipleuploadfile-ocmultipleuploadfile--docs",
  "props": {
    "modelValue": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "accept": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "validateAcceptFileType": {
      "type": "boolean",
      "required": false
    },
    "maxSize": {
      "type": "number",
      "required": false,
      "description": "Maximum file size in MB"
    },
    "maxImages": {
      "type": "number",
      "required": false
    },
    "hint": {
      "type": "string",
      "required": false
    },
    "label": {
      "type": "string",
      "required": false
    },
    "errorMessage": {
      "type": "string",
      "required": false
    },
    "isImageOnly": {
      "type": "boolean",
      "required": false
    },
    "showErrorStyleOnly": {
      "type": "boolean",
      "required": false
    },
    "columnsCount": {
      "type": "number",
      "required": false
    },
    "selectedImage": {
      "type": "object",
      "required": false,
      "default": "{}"
    },
    "inputOptions": {
      "type": "array",
      "required": false
    },
    "isDisabled": {
      "type": "boolean",
      "required": false
    },
    "confirmToRemove": {
      "type": "boolean",
      "required": false
    },
    "labelUploadArea": {
      "type": "string",
      "required": false
    },
    "isButtonOnly": {
      "type": "boolean",
      "required": false
    },
    "buttonUploadProps": {
      "type": "object",
      "required": false,
      "default": "{\n  label: 'Upload'\n}"
    }
  },
  "events": {
    "update:selectedImage": {
      "description": ""
    },
    "update:modelValue": {
      "description": ""
    },
    "onEditFile": {
      "description": ""
    },
    "onRemoveFile": {
      "description": ""
    },
    "onMaxFileExceed": {
      "description": ""
    },
    "onOpenEditImage": {
      "description": ""
    },
    "onImageError": {
      "description": ""
    },
    "onExceedMaxFileSize": {
      "description": ""
    },
    "confirmRemoveFile": {
      "description": ""
    }
  },
  "slots": {
    "action": {
      "description": "",
      "bindings": [
        {
          "name": "item"
        },
        {
          "name": "remove-item"
        },
        {
          "name": "file-index"
        }
      ]
    },
    "button": {
      "description": "",
      "bindings": [
        {
          "name": "trigger-input"
        }
      ]
    },
    "progress": {
      "description": "",
      "bindings": [
        {
          "name": "current-index"
        },
        {
          "name": "current-file"
        }
      ]
    },
    "hint": {
      "description": ""
    }
  },
  "rules": [],
  "examples": [
    {
      "name": "Default",
      "props": {
        "maxSize": 5,
        "isImageOnly": false,
        "columnsCount": 3,
        "isButtonOnly": true,
        "buttonUploadProps": {
          "label": "Upload",
          "leftIcon": "upload"
        }
      }
    }
  ]
}