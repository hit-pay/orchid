{
  "name": "MultipleUploadFile",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-multipleuploadfile-ocmultipleuploadfile--docs",
  "props": {
    "modelValue": {
      "type": "array",
      "required": false,
      "default": "[]"
    },
    "accept": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "validateAcceptFileType": {
      "type": "boolean",
      "required": false
    },
    "maxSize": {
      "type": "number",
      "required": false,
      "description": "Maximum file size in MB"
    },
    "maxImages": {
      "type": "number",
      "required": false
    },
    "hint": {
      "type": "string",
      "required": false
    },
    "label": {
      "type": "string",
      "required": false
    },
    "errorMessage": {
      "type": "string",
      "required": false
    },
    "isImageOnly": {
      "type": "boolean",
      "required": false
    },
    "showErrorStyleOnly": {
      "type": "boolean",
      "required": false
    },
    "columnsCount": {
      "type": "number",
      "required": false
    },
    "selectedImage": {
      "type": "object",
      "required": false,
      "default": "{}"
    },
    "inputOptions": {
      "type": "array",
      "required": false
    },
    "isDisabled": {
      "type": "boolean",
      "required": false
    },
    "confirmToRemove": {
      "type": "boolean",
      "required": false
    },
    "labelUploadArea": {
      "type": "string",
      "required": false
    },
    "isButtonOnly": {
      "type": "boolean",
      "required": false
    },
    "buttonUploadProps": {
      "type": "object",
      "required": false,
      "default": "{\n  label: 'Upload'\n}"
    }
  },
  "events": {
    "update:selectedImage": {
      "description": ""
    },
    "update:modelValue": {
      "description": ""
    },
    "onEditFile": {
      "description": ""
    },
    "onRemoveFile": {
      "description": ""
    },
    "onMaxFileExceed": {
      "description": ""
    },
    "onOpenEditImage": {
      "description": ""
    },
    "onImageError": {
      "description": ""
    },
    "onExceedMaxFileSize": {
      "description": ""
    },
    "confirmRemoveFile": {
      "description": ""
    }
  },
  "slots": {
    "action": {
      "description": "",
      "bindings": [
        {
          "name": "item"
        },
        {
          "name": "remove-item"
        },
        {
          "name": "file-index"
        }
      ]
    },
    "button": {
      "description": "",
      "bindings": [
        {
          "name": "trigger-input"
        }
      ]
    },
    "progress": {
      "description": "",
      "bindings": [
        {
          "name": "current-index"
        },
        {
          "name": "current-file"
        }
      ]
    },
    "hint": {
      "description": ""
    }
  },
  "rules": [],
  "examples": [
    {
      "name": "Default",
      "props": {
        "maxSize": 5,
        "isImageOnly": false,
        "columnsCount": 3,
        "isButtonOnly": true,
        "buttonUploadProps": {
          "label": "Upload",
          "leftIcon": "upload"
        }
      },
      "code": "<Theme class=\"min-h-[500px]\">\n        <MultipleUploadFile v-model=\"modelValue\" v-bind=\"args\" />\n      </Theme>"
    },
    {
      "name": "MultipleImages",
      "code": "<Theme class=\"min-h-[500px]\">\n        <MultipleUploadFile\n          v-model=\"modelValue\"\n          is-image-only\n          label=\"Product Images\"\n          hint=\"The optimal product image size is at least 800x800 px. PNG and JPG format is supported.\"\n          :max-images=\"4\"\n          :columns-count=\"3\"\n          :input-options=\"['caption', 'link', 'lightbox', 'new_tab']\"\n        />\n      </Theme>"
    }
  ],
  "relatedComponents": []
}