        "legendData": [
          "Running shoes",
          "Women's ribbed top",
          "Fleece sweatshirt",
          "Sportswear Tech Fleece",
          "Joggers",
          "Joggers"
        ]
      },
      "code": "<Theme>\n        <BarRaceChart class=\"h-[300px]\" v-bind=\"args\" />\n      </Theme>"
    }
  ],
  "relatedComponents": []
}