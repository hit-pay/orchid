        "primary",
        "purple"
      ]
    },
    "showTooltip": {
      "type": "boolean",
      "required": false
    },
    "showLegend": {
      "type": "boolean",
      "required": false
    },
    "showGrid": {
      "type": "boolean",
      "required": false
    },
    "chartData": {
      "type": "array",
      "required": false
    },
    "labelData": {
      "type": "array",
      "required": false
    },
    "legendData": {
      "type": "array",
      "required": false
    },
    "yAxisFormatter": {
      "type": "func",
      "required": false
    },
    "tooltipFormatter": {
      "type": "func",
      "required": false
    },
    "tooltipValueFormatter": {
      "type": "func",
      "required": false
    }
  },
  "events": {},
  "slots": {
    "legend-item": {
      "description": "",
