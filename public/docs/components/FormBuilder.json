{
  "name": "FormBuilder",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/formbuilder-ocformbuilder--docs",
  "props": {
    "id": {
      "type": "string",
      "required": true
    },
    "jsonForm": {
      "type": "array",
      "required": false
    },
    "grid": {
      "type": "object",
      "required": false,
      "default": "null",
      "description": "Grid needs to be defined in the following format:\n`{`\n  `[Responsive size (xs, sm, md, lg, xl, xxl)]: {`\n    `area: [Grid area definition (names of areas in order)],`\n    `rows: [Count and size of rows i.e: 'auto' | '100%' | ...],`\n    `columns: [Count and size of columns i.e: '33% 33% 33%'],`\n  `}`\n`}`"
    },
    "class": {
      "type": "string",
      "required": false
    },
    "errors": {
      "type": "object",
      "required": false
    },
    "values": {
      "type": "object",
      "required": true
    },
    "logicValues": {
      "type": "object",
      "required": false
    },
    "previewMode": {
      "type": "string",
      "required": false
    }
  },
  "events": {
    "onUpdate": {
      "description": ""
    }
  },
  "slots": {
    "form.type": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        },
        {
          "name": "form-id"
        },
        {
          "name": "form"
        },
        {
          "name": "value"
        },
        {
          "name": "error"
        },
        {
          "name": "on-update"
        }
      ]
    }
  },
  "rules": [
    "Required props: id, values"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "values": {
          "range_input": [
            0,
            100
          ]
        },
        "errors": {
          "card_input": ""
        },
        "grid": {
          "xs": {
            "area": "\n          input\n          card_input\n          custom_form_input\n          simple_checkbox_input\n          checkboxes_group\n          input_2\n          custom_form_input_2\n          link_input\n          phone_number_field\n          radio_group\n          radio_group_2\n          select\n          text_area_field\n          range_input\n          time_picker_test\n          date_picker_test\n          date_picker_range_from\n          toggle_field\n        ",
            "rows": "auto",
            "columns": "100%"
          },
          "sm": {
            "area": "\n          input\n          card_input\n          custom_form_input\n          simple_checkbox_input\n          checkboxes_group\n          input_2\n          custom_form_input_2\n          link_input\n          phone_number_field\n          radio_group\n          radio_group_2\n          select\n          text_area_field\n          range_input\n          time_picker_test\n          date_picker_test\n          date_picker_range_from\n          toggle_field\n        ",
            "rows": "auto",
            "columns": "100%"
          },
          "lg": {
            "area": "\n          input card_input\n          custom_form_input simple_checkbox_input\n          checkboxes_group input_2\n          custom_form_input_2 link_input\n          phone_number_field radio_group\n          radio_group_2 select\n          text_area_field range_input\n          time_picker_test date_picker_test\n          date_picker_range_from toggle_field\n        ",
            "rows": "auto",
            "columns": "50% 50%"
          }
        }
      },
      "code": "<Theme class=\"p-8\">\n        <FormBuilder\n          id=\"form-builder\"\n          class=\"gap-5\"\n          :errors=\"errors\"\n          :grid=\"args.grid\"\n          :values=\"values\"\n          :json-form=\"SampleJsonForm\"\n          @onUpdate=\"onUpdateForm\"\n        >\n          <template #CustomFormInput=\"{form, value, error}\">\n            <div class=\"flex items-center md:col-span-2 border-2 p-3\">\n              <label class=\"mr-3\">This custom form input</label>\n              <Button @click=\"onUpdateForm(form, '1')\">Set Value to (1)</Button>\n              <span>{{ error }}</span>\n            </div>\n          </template>\n          <template #CustomFormInput2=\"{form, value, error}\">\n            <Input\n              label=\"Custom Form Input 2\"\n              hint=\"This is a hint text to help user\"\n              :model-value=\"value\"\n              :error-message=\"error\"\n              @update:model-value=\"onUpdateForm(form, $event)\"\n            >\n              <template #trailing>\n                <Dropdown v-model=\"isOpenedDropdown\">\n                  <template #menu>\n                    <div class=\"flex p-2 flex-col\">\n                      <DropdownItem text=\"Menu\" icon=\"pencil\" @click=\"isOpenedDropdown=false\"/>\n                      <DropdownItem text=\"Menu\" icon=\"pencil\" @click=\"isOpenedDropdown=false\"/>\n                      <DropdownItem text=\"Menu\" icon=\"pencil\" @click=\"isOpenedDropdown=false\"/>\n                    </div>\n                  </template>\n                  <div class=\"text-sm font-medium flex items-center gap-x-2 text-oc-text-400\">\n                    <span class=\"flex items-center text-sm\">USD</span>\n                    <Icon class=\"w-[14px] h-[14px]\" name=\"chevron-down\"/>\n                  </div>\n                </Dropdown>\n              </template>\n            </Input>\n          </template>\n        </FormBuilder>\n      </Theme>"
    },
    {
      "name": "ShowIfLogic",
      "props": {
        "values": {
          "select_product_from": "all_product",
          "limit_feature_product": false,
          "other_value": false,
          "slider": 10
        },
        "errors": {}
      },
      "code": "<Theme class=\"p-8\">\n        <div class=\"mb-10 pb-10 border-b\">\n          {{ values }}\n        </div>\n\n        <FormBuilder\n          id=\"form-builder\"\n          class=\"grid gap-4\"\n          :errors=\"errors\"\n          :values=\"values\"\n          :json-form=\"JsonForm\"\n          @onUpdate=\"onUpdateForm\"\n        >\n          <template #Children=\"{form}\">{{form}}</template>\n        </FormBuilder>\n      </Theme>"
    }
  ],
  "relatedComponents": [
    "Button",
    "Dropdown",
    "DropdownItem",
    "Icon",
    "Input"
  ]
}