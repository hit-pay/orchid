{
  "name": "Calendar",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-calendar-occalendar--docs",
  "props": {
    "type": {
      "type": "string",
      "required": false,
      "default": "default"
    },
    "minDate": {
      "type": "string|date|number",
      "required": false,
      "default": "null"
    },
    "maxDate": {
      "type": "string|date|number",
      "required": false,
      "default": "null"
    },
    "position": {
      "type": "string",
      "required": false,
      "default": "floating"
    },
    "modelValue": {
      "type": "string|date|number|array",
      "required": false,
      "default": "null"
    },
    "disabledDate": {
      "type": "func",
      "required": false,
      "default": "() => false"
    },
    "isIndefinite": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "inDefiniteLabel": {
      "type": "string",
      "required": false,
      "default": "Indefinite"
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    },
    "reset-calendar": {
      "description": ""
    },
    "update:isIndefinite": {
      "description": ""
    }
  },
  "slots": {
    "bottom": {
      "description": ""
    }
  },
  "rules": [],
  "examples": [
    {
      "name": "Default",
      "props": {
        "isRange": false,
        "isMultiple": false,
        "disabledDates": []
      },
      "code": "<Theme>\n        <Calendar v-model=\"modelValue\" v-bind=\"args\" />\n      </Theme>"
    },
    {
      "name": "RangeCalendar",
      "code": "<Theme>\n        <Calendar v-model=\"modelValue\" type=\"range\" />\n      </Theme>"
    }
  ],
  "relatedComponents": []
}