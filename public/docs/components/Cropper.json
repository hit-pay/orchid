{
  "name": "Cropper",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-cropper-occropper--docs",
  "props": {
    "inputOptions": {
      "type": "array",
      "required": false
    },
    "inputOptionValues": {
      "type": "object",
      "required": false
    },
    "img": {
      "type": "string",
      "required": false
    },
    "maxSize": {
      "type": "string|number",
      "required": false
    },
    "isReplaceImage": {
      "type": "boolean",
      "required": false,
      "default": "true"
    }
  },
  "events": {
    "changeImage": {
      "description": ""
    },
    "update:input-options": {
      "description": ""
    }
  },
  "slots": {},
  "rules": [],
  "examples": [
    {
      "name": "Default",
      "props": {
        "img": "/images/image.jpg",
        "isReplaceImage": true
      },
      "code": "<Theme class=\"min-h-[500px]\">\n        <Cropper\n          v-bind=\"args\"\n          :input-options=\"['description', 'link', 'caption', 'lightbox', 'new_tab']\"\n          :input-option-values=\"inputOptionValues\"\n          @update:input-options=\"inputOptionValues = $event\"\n        />\n      </Theme>"
    }
  ],
  "relatedComponents": []
}