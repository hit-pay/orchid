{
  "name": "Variant",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/disclosure-variants-ocvariant--docs",
  "props": {
    "icon": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "label": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "isActive": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isDisabled": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "iconOptions": {
      "type": "object",
      "required": false,
      "default": "null"
    },
    "value": {
      "type": "string|number",
      "required": false,
      "default": ""
    }
  },
  "events": {},
  "slots": {
    "`${value}-description`": {
      "description": "",
      "bindings": [
        {
          "name": "name"
        }
      ]
    }
  },
  "rules": [],
  "examples": []
}