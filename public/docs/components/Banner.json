{
  "name": "Banner",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/feedback-banner-ocbanner--docs",
  "props": {
    "modelValue": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "color": {
      "type": "enum",
      "required": false,
      "default": "default",
      "values": [
        "default",
        "primary",
        "error",
        "warning",
        "gray"
      ]
    },
    "content": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "icon": {
      "type": "enum",
      "required": false,
      "default": "filled-check",
      "values": [
        "filled-check",
        "circle",
        "plus",
        "x"
      ]
    },
    "showIcon": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "dismissible": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "transitionName": {
      "type": "string",
      "required": false,
      "default": "slide-from-top"
    },
    "title": {
      "type": "string",
      "required": false,
      "default": ""
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {
    "title": {
      "description": ""
    },
    "default": {
      "description": ""
    }
  },
  "rules": [
    "\"color\" must be one of: default, primary, error, warning, gray",
    "\"icon\" must be one of: filled-check, circle, plus, x"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "color": "default",
        "icon": "filled-check",
        "title": "Title",
        "content": "Changes have been successfully saved",
        "showIcon": true,
        "dismissible": true,
        "transitionName": "slide-from-top"
      },
      "code": "<Theme class=\"h-[300px]\">\n        <Banner v-model=\"modelValue\" v-bind=\"args\" />\n      </Theme>"
    },
    {
      "name": "Variants",
      "code": "<Theme>\n        <div class=\"flex flex-col gap-y-4\">\n          <Banner :model-value=\"true\" title=\"Title\" content=\"Changes have been successfully saved\" show-icon icon=\"filled-check\" />\n          <Banner :model-value=\"true\" color=\"primary\" title=\"Title\" content=\"Changes have been successfully saved\" show-icon icon=\"filled-check\" />\n          <Banner :model-value=\"true\" color=\"error\" title=\"Title\" content=\"Changes have been successfully saved\" show-icon icon=\"filled-check\" />\n          <Banner :model-value=\"true\" color=\"warning\" title=\"Title\" content=\"Changes have been successfully saved\" show-icon icon=\"filled-check\" />\n          <Banner :model-value=\"true\" color=\"gray\" title=\"Title\" content=\"Changes have been successfully saved\" show-icon icon=\"filled-check\" />\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}