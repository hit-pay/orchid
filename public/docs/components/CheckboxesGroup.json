{
  "name": "CheckboxesGroup",
  "description": "A group of checkboxes with select-all support and vertical/horizontal alignment.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-checkboxesgroup-occheckboxesgroup--docs",
  "props": {
    "alignment": {
      "type": "enum",
      "required": false,
      "default": "vertical",
      "values": [
        "vertical",
        "horizontal"
      ]
    },
    "checkboxes": {
      "type": "array",
      "required": false
    },
    "modelValue": {
      "type": "array|string",
      "required": false
    },
    "label": {
      "type": "string",
      "required": false
    },
    "errorMessage": {
      "type": "string",
      "required": false
    },
    "hint": {
      "type": "string",
      "required": false
    },
    "isDisabled": {
      "type": "boolean",
      "required": false
    },
    "isSelectAll": {
      "type": "boolean",
      "required": false
    },
    "isButtonVariant": {
      "type": "boolean",
      "required": false
    },
    "isBlock": {
      "type": "boolean",
      "required": false
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {},
  "rules": [
    "\"alignment\" must be one of: vertical, horizontal"
  ],
  "examples": []
}