{
  "name": "CheckboxesGroup",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-checkboxesgroup-occheckboxesgroup--docs",
  "props": {
    "alignment": {
      "type": "enum",
      "required": false,
      "default": "vertical",
      "values": [
        "vertical",
        "horizontal"
      ]
    },
    "checkboxes": {
      "type": "array",
      "required": false
    },
    "modelValue": {
      "type": "array|string",
      "required": false
    },
    "label": {
      "type": "string",
      "required": false
    },
    "errorMessage": {
      "type": "string",
      "required": false
    },
    "hint": {
      "type": "string",
      "required": false
    },
    "isDisabled": {
      "type": "boolean",
      "required": false
    },
    "isSelectAll": {
      "type": "boolean",
      "required": false
    },
    "isButtonVariant": {
      "type": "boolean",
      "required": false
    },
    "isBlock": {
      "type": "boolean",
      "required": false
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {},
  "rules": [
    "\"alignment\" must be one of: vertical, horizontal"
  ],
  "examples": [
    {
      "name": "Default",
      "code": "<Theme>\n        <CheckboxesGroup\n          v-model=\"modelValue\"\n          v-bind=\"args\"\n        />\n      </Theme>"
    },
    {
      "name": "Variants",
      "code": "<Theme>\n        <div class=\"flex flex-col gap-y-6\">\n          <CheckboxesGroup\n            v-model=\"vertical\"\n            label=\"Vertical (default)\"\n            hint=\"Select one or more options.\"\n            alignment=\"vertical\"\n            :checkboxes=\"[\n              { label: 'Option 1', value: 1 },\n              { label: 'Option 2', value: 2 },\n              { label: 'Option 3', value: 3 }\n            ]\"\n          />\n          <CheckboxesGroup\n            v-model=\"horizontal\"\n            label=\"Horizontal\"\n            alignment=\"horizontal\"\n            :checkboxes=\"[\n              { label: 'Option 1', value: 1 },\n              { label: 'Option 2', value: 2 },\n              { label: 'Option 3', value: 3 }\n            ]\"\n          />\n          <CheckboxesGroup\n            v-model=\"disabledValue\"\n            label=\"Disabled\"\n            :is-disabled=\"true\"\n            :checkboxes=\"[\n              { label: 'Option 1', value: 1 },\n              { label: 'Option 2', value: 2 },\n              { label: 'Option 3', value: 3 }\n            ]\"\n          />\n          <CheckboxesGroup\n            v-model=\"withError\"\n            label=\"With Error\"\n            error-message=\"Please select at least one option.\"\n            :checkboxes=\"[\n              { label: 'Option 1', value: 1 },\n              { label: 'Option 2', value: 2 },\n              { label: 'Option 3', value: 3 }\n            ]\"\n          />\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}