{
  "name": "TextArea",
  "description": "A multi-line text input with auto-resize, label, hint, and error support.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-textarea-octextarea--docs",
  "props": {
    "placeholder": {
      "type": "string",
      "required": false
    },
    "label": {
      "type": "string",
      "required": false
    },
    "errorMessage": {
      "type": "string",
      "required": false
    },
    "hint": {
      "type": "string",
      "required": false
    },
    "modelValue": {
      "type": "string",
      "required": false
    },
    "rows": {
      "type": "number",
      "required": false
    },
    "autoResize": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isDisabled": {
      "type": "boolean",
      "required": false
    },
    "isRequired": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "labelIcon": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipText": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipOptions": {
      "type": "object",
      "required": false,
      "default": "{}"
    },
    "ai": {
      "type": "boolean",
      "required": false,
      "default": "false"
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {},
  "rules": [],
  "examples": [
    {
      "name": "Default",
      "props": {
        "label": "Label",
        "hint": "This is a hint text to help user.",
        "placeholder": "Placeholder",
        "disabled": false,
        "isRequired": false,
        "rows": 5
      }
    }
  ]
}