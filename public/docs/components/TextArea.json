{
  "name": "TextArea",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-textarea-octextarea--docs",
  "props": {
    "placeholder": {
      "type": "string",
      "required": false
    },
    "label": {
      "type": "string",
      "required": false
    },
    "errorMessage": {
      "type": "string",
      "required": false
    },
    "hint": {
      "type": "string",
      "required": false
    },
    "modelValue": {
      "type": "string",
      "required": false
    },
    "rows": {
      "type": "number",
      "required": false
    },
    "autoResize": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isDisabled": {
      "type": "boolean",
      "required": false
    },
    "isRequired": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "labelIcon": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipText": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "tooltipOptions": {
      "type": "object",
      "required": false,
      "default": "{}"
    },
    "ai": {
      "type": "boolean",
      "required": false,
      "default": "false"
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {},
  "rules": [],
  "examples": [
    {
      "name": "Default",
      "props": {
        "label": "Label",
        "hint": "This is a hint text to help user.",
        "placeholder": "Placeholder",
        "disabled": false,
        "isRequired": false,
        "rows": 5
      },
      "code": "<Theme>\n        <TextArea\n          v-model=\"modelValue\"\n          v-bind=\"args\"\n        />\n      </Theme>"
    },
    {
      "name": "Variants",
      "code": "<Theme>\n        <div class=\"flex flex-col gap-y-6\">\n          <TextArea\n            v-model=\"normal\"\n            label=\"Normal\"\n            hint=\"This is a hint text.\"\n            placeholder=\"Placeholder\"\n            :rows=\"4\"\n          />\n          <TextArea\n            v-model=\"disabled\"\n            label=\"Disabled\"\n            hint=\"This is a hint text.\"\n            placeholder=\"Placeholder\"\n            :rows=\"4\"\n            :is-disabled=\"true\"\n          />\n          <TextArea\n            v-model=\"error\"\n            label=\"Error\"\n            hint=\"This is a hint text.\"\n            placeholder=\"Placeholder\"\n            :rows=\"4\"\n            error-message=\"This field is required.\"\n          />\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}