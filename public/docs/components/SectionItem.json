{
  "name": "SectionItem",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-sectionitem-ocsectionitem--docs",
  "props": {
    "title": {
      "type": "string",
      "required": false
    },
    "description": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "descriptionClass": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "icon": {
      "type": "enum",
      "required": false,
      "values": [
        "information",
        "check",
        "x"
      ]
    },
    "modelValue": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isToggle": {
      "type": "boolean",
      "required": false
    },
    "toggleProps": {
      "type": "object",
      "required": false
    },
    "popperMessage": {
      "type": "string",
      "required": false
    },
    "errorMessage": {
      "type": "string",
      "required": false
    },
    "defaultValue": {
      "type": "boolean",
      "required": false
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {
    "actions": {
      "description": ""
    }
  },
  "rules": [
    "\"icon\" must be one of: information, check, x"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "title": "Title",
        "description": "Description",
        "isToggle": true,
        "icon": "check",
        "popperMessage": "Information"
      },
      "code": "<Theme>\n        <SectionItem\n          v-model=\"modelValue\"\n          v-bind=\"args\"\n        />\n      </Theme>"
    },
    {
      "name": "Variants",
      "code": "<Theme>\n        <div class=\"flex flex-col gap-y-4 p-4\">\n          <SectionItem\n            v-model=\"toggle1\"\n            title=\"Default\"\n            description=\"A section item with a toggle.\"\n            :is-toggle=\"true\"\n            icon=\"check\"\n          />\n          <SectionItem\n            v-model=\"toggle2\"\n            title=\"Enabled by default\"\n            description=\"This section item is toggled on.\"\n            :is-toggle=\"true\"\n            icon=\"check\"\n          />\n          <SectionItem\n            v-model=\"toggle3\"\n            title=\"With error\"\n            description=\"This section item has an error message.\"\n            :is-toggle=\"true\"\n            icon=\"information\"\n            error-message=\"This setting is required.\"\n          />\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}