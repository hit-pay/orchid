{
  "name": "SectionItem",
  "description": "A settings row with a title, description, optional toggle, and action slot.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-sectionitem-ocsectionitem--docs",
  "props": {
    "title": {
      "type": "string",
      "required": false
    },
    "description": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "descriptionClass": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "icon": {
      "type": "enum",
      "required": false,
      "values": [
        "information",
        "check",
        "x"
      ]
    },
    "modelValue": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "isToggle": {
      "type": "boolean",
      "required": false
    },
    "toggleProps": {
      "type": "object",
      "required": false
    },
    "popperMessage": {
      "type": "string",
      "required": false
    },
    "errorMessage": {
      "type": "string",
      "required": false
    },
    "defaultValue": {
      "type": "boolean",
      "required": false
    }
  },
  "events": {
    "update:modelValue": {
      "description": ""
    }
  },
  "slots": {
    "actions": {
      "description": ""
    }
  },
  "rules": [
    "\"icon\" must be one of: information, check, x"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "title": "Title",
        "description": "Description",
        "isToggle": true,
        "icon": "check",
        "popperMessage": "Information"
      }
    }
  ]
}