{
  "name": "Checklist",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/elements-checklist-occhecklist--docs",
  "props": {
    "index": {
      "type": "number",
      "required": true
    },
    "label": {
      "type": "string",
      "required": true
    },
    "completed": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "active": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "actionButton": {
      "type": "object",
      "required": false
    }
  },
  "events": {},
  "slots": {},
  "rules": [
    "Required props: index, label"
  ],
  "examples": [
    {
      "name": "Default",
      "code": "<Theme>\n        <div class=\"flex flex-col\">\n          <Checklist\n            label=\"Account verifications\"\n            completed\n            :index=\"1\"\n            :action-button=\"{ label: 'Completed' }\"\n          />\n          <Checklist\n            label=\"Add bank account\"\n            active\n            :index=\"2\"\n            :action-button=\"{ label: 'Continue' }\"\n          />\n          <Checklist\n            label=\"Add bank account\"\n            index=\"3\"\n            :action-button=\"{ label: 'Setup' }\"\n          />\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}