{
  "name": "EmptyPage",
  "description": "A placeholder page shown when a list or section has no data.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/elements-emptypage-ocemptypage--docs",
  "props": {
    "isButton": {
      "type": "boolean",
      "required": false,
      "default": "true"
    },
    "title": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "description": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "isUpgrade": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "containerClass": {
      "type": "array|string",
      "required": false
    },
    "upgradeLabel": {
      "type": "string",
      "required": false,
      "default": "Upgrade now"
    },
    "addButtonLabel": {
      "type": "string",
      "required": false,
      "default": "Add new"
    },
    "addButtonIcon": {
      "type": "string",
      "required": false,
      "default": "plus"
    },
    "icon": {
      "type": "string",
      "required": false,
      "default": "document"
    },
    "size": {
      "type": "enum",
      "required": false,
      "default": "default",
      "values": [
        "large",
        "default",
        "small"
      ]
    },
    "hideBadge": {
      "type": "boolean",
      "required": false,
      "default": "false"
    },
    "secondaryButton": {
      "type": "object",
      "required": false,
      "default": "() => null"
    }
  },
  "events": {
    "click:button": {
      "description": ""
    }
  },
  "slots": {
    "icon": {
      "description": ""
    },
    "description": {
      "description": ""
    }
  },
  "rules": [
    "\"size\" must be one of: large, default, small"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "title": "Title",
        "description": "Description",
        "isButton": true,
        "isUpgrade": true,
        "addButtonLabel": "Add new",
        "upgradeLabel": "Upgrade now",
        "size": "default"
      }
    }
  ]
}