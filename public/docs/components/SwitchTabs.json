{
  "name": "SwitchTabs",
  "description": "A segmented control for switching between a small set of options.",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/disclosure-switchtabs-ocswitchtabs--docs",
  "props": {
    "options": {
      "type": "array",
      "required": true
    },
    "activeOption": {
      "type": "string",
      "required": false,
      "default": ""
    }
  },
  "events": {
    "select": {
      "description": ""
    }
  },
  "slots": {},
  "rules": [
    "Required props: options"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "options": [
          {
            "label": "Weekly",
            "value": "weekly"
          },
          {
            "label": "Monthly",
            "value": "monthly"
          },
          {
            "label": "Yearly",
            "value": "annually"
          }
        ]
      }
    }
  ]
}