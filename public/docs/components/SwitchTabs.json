{
  "name": "SwitchTabs",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/disclosure-switchtabs-ocswitchtabs--docs",
  "props": {
    "options": {
      "type": "array",
      "required": true
    },
    "activeOption": {
      "type": "string",
      "required": false,
      "default": ""
    }
  },
  "events": {
    "select": {
      "description": ""
    }
  },
  "slots": {},
  "rules": [
    "Required props: options"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "options": [
          {
            "label": "Weekly",
            "value": "weekly"
          },
          {
            "label": "Monthly",
            "value": "monthly"
          },
          {
            "label": "Yearly",
            "value": "annually"
          }
        ]
      },
      "code": "<Theme>\n        <div class=\"flex items-center justify-center\">\n          <SwitchTabs v-bind=\"args\" :active-option=\"activeOption\" @select=\"activeOption = $event\" />\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}