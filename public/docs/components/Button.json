{
  "name": "Button",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/form-button-ocbutton--docs",
  "props": {
    "label": {
      "type": "string",
      "required": false
    },
    "isDisabled": {
      "type": "boolean",
      "required": false
    },
    "isLoading": {
      "type": "boolean",
      "required": false
    },
    "leftIcon": {
      "type": "enum",
      "required": false,
      "values": [
        "circle",
        "x"
      ]
    },
    "iconClass": {
      "type": "array|string",
      "required": false
    },
    "additionalAreaIcon": {
      "type": "enum",
      "required": false,
      "values": [
        "chevron-down",
        "circle"
      ]
    },
    "isAdditionalArea": {
      "type": "boolean",
      "required": false
    },
    "rightIcon": {
      "type": "enum",
      "required": false,
      "values": [
        "plus",
        "circle"
      ]
    },
    "isActive": {
      "type": "boolean",
      "required": false
    },
    "isTransparent": {
      "type": "boolean",
      "required": false
    },
    "isRoundedFull": {
      "type": "boolean",
      "required": false
    },
    "variant": {
      "type": "enum",
      "required": false,
      "default": "primary",
      "values": [
        "primary",
        "secondary",
        "destructive"
      ]
    },
    "size": {
      "type": "enum",
      "required": false,
      "default": "default",
      "values": [
        "default",
        "small",
        "big"
      ]
    }
  },
  "events": {
    "addition-click": {
      "description": ""
    }
  },
  "slots": {
    "default": {
      "description": ""
    },
    "additional-content": {
      "description": ""
    }
  },
  "rules": [
    "\"leftIcon\" must be one of: circle, x",
    "\"additionalAreaIcon\" must be one of: chevron-down, circle",
    "\"rightIcon\" must be one of: plus, circle",
    "\"variant\" must be one of: primary, secondary, destructive",
    "\"size\" must be one of: default, small, big"
  ],
  "examples": [
    {
      "name": "Default",
      "props": {
        "label": "Button Text",
        "variant": "primary",
        "size": "default",
        "isDisabled": false,
        "isLoading": false,
        "isTransparent": false,
        "isRoundedFull": false,
        "isAdditionalArea": false,
        "additionalAreaIcon": "chevron-down"
      },
      "code": "<Theme>\n        <Button v-bind=\"args\" />\n      </Theme>"
    },
    {
      "name": "SizeVariants",
      "code": "<Theme>\n        <div class=\"flex flex-col gap-3\">\n          <div class=\"flex gap-3 items-center\">\n            <Button size=\"small\" label=\"Button Text\" />\n            <Button label=\"Button Text\" />\n            <Button size=\"big\" label=\"Button Text\" />\n          </div>\n          <div class=\"flex gap-3 items-center\">\n            <Button size=\"small\" variant=\"secondary\" label=\"Button Text\" />\n            <Button variant=\"secondary\" label=\"Button Text\" />\n            <Button size=\"big\" variant=\"secondary\" label=\"Button Text\" />\n          </div>\n          <div class=\"flex gap-3 items-center\">\n            <Button size=\"small\" variant=\"destructive\" label=\"Button Text\" />\n            <Button variant=\"destructive\" label=\"Button Text\" />\n            <Button size=\"big\" variant=\"destructive\" label=\"Button Text\" />\n          </div>\n        </div>\n      </Theme>"
    },
    {
      "name": "ButtonVariants",
      "code": "<Theme>\n        <div class=\"flex flex-col gap-3\">\n          <div class=\"flex gap-5 items-center\">\n            <Button left-icon=\"x\" />\n            <Button left-icon=\"x\" right-icon=\"circle\" label=\"Button Text\" />\n            <Button label=\"Button Text\" is-disabled />\n            <Button label=\"Button Text\" is-loading />\n            <Button label=\"Button Text\" is-transparent />\n            <Button label=\"Button Text\" is-additional-area additional-area-icon=\"chevron-down\" />\n          </div>\n          <div class=\"flex gap-5 items-center\">\n            <Button variant=\"secondary\" left-icon=\"x\" />\n            <Button variant=\"secondary\" left-icon=\"x\" right-icon=\"circle\" label=\"Button Text\" />\n            <Button variant=\"secondary\" label=\"Button Text\" is-disabled />\n            <Button variant=\"secondary\" label=\"Button Text\" is-loading />\n            <Button variant=\"secondary\" label=\"Button Text\" is-transparent />\n            <Button variant=\"secondary\" label=\"Button Text\" is-additional-area additional-area-icon=\"chevron-down\" />\n          </div>\n          <div class=\"flex gap-5 items-center\">\n            <Button variant=\"destructive\" left-icon=\"x\" />\n            <Button variant=\"destructive\" left-icon=\"x\" right-icon=\"circle\" label=\"Button Text\" />\n            <Button variant=\"destructive\" label=\"Button Text\" is-disabled />\n            <Button variant=\"destructive\" label=\"Button Text\" is-loading />\n            <Button variant=\"destructive\" label=\"Button Text\" is-transparent />\n            <Button variant=\"destructive\" label=\"Button Text\" is-additional-area additional-area-icon=\"chevron-down\" />\n          </div>\n        </div>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}