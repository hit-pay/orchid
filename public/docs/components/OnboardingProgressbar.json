{
  "name": "OnboardingProgressbar",
  "storybook": "https://orchidui.vercel.app/storybook/?path=/docs/dashboard-onboardingprogressbar-oconboardingprogressbar--docs",
  "props": {
    "title": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "description": {
      "type": "string",
      "required": false,
      "default": ""
    },
    "value": {
      "type": "string|number",
      "required": false,
      "default": "0"
    },
    "chartData": {
      "type": "array",
      "required": false,
      "default": "[]"
    }
  },
  "events": {},
  "slots": {
    "description": {
      "description": ""
    }
  },
  "rules": [],
  "examples": [
    {
      "name": "Default",
      "props": {
        "value": 50,
        "title": "We are verifying your account!",
        "chartData": [
          {
            "value": 60,
            "name": "Primary",
            "itemStyle": {
              "color": "#2465DE"
            }
          },
          {
            "value": 20,
            "name": "Warning",
            "itemStyle": {
              "color": "#FFD47D"
            }
          },
          {
            "value": 20,
            "name": "Empty",
            "itemStyle": {
              "color": "#F8F9FC"
            }
          }
        ]
      },
      "code": "<Theme>\n        <OnboardingProgressbar v-bind=\"args\">\n          <template #description>\n            <span class=\"text-sm text-oc-text-400\">\n              It usually takes\n              <span class=\"font-medium text-oc-text\">2 work days</span>\n              . We will let you know once it's done.\n            </span>\n          </template>\n        </OnboardingProgressbar>\n      </Theme>"
    }
  ],
  "relatedComponents": []
}